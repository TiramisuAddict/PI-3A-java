<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="400.0" prefWidth="500.0" spacing="20.0" style="-fx-background-color: -color-base-0;" stylesheets="@customTheme.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.formations.ModifierRaisonController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>
    <children>
        <!-- Header -->
        <VBox spacing="10.0" style="-fx-background-color: linear-gradient(to right, #667eea 0%, #764ba2 100%); -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 15, 0, 0, 3);">
            <children>
                <Label style="-fx-font-weight: bold; -fx-font-size: 24px; -fx-text-fill: white;" text="✏️ Modifier la Raison" />
                <Label text="Mettez à jour votre motivation pour cette formation" style="-fx-text-fill: rgba(255,255,255,0.9); -fx-font-size: 13px;" />
            </children>
        </VBox>

        <!-- Formation Info -->
        <VBox spacing="8.0" style="-fx-background-color: #f8f9fa; -fx-background-radius: 8; -fx-padding: 15;">
            <children>
                <HBox spacing="10.0">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #495057;" text="📚 Formation:" />
                        <Label fx:id="lblFormationTitre" text="-" style="-fx-text-fill: #212529;" />
                    </children>
                </HBox>
                <HBox spacing="10.0">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #495057;" text="📊 Statut:" />
                        <Label fx:id="lblStatut" text="-" style="-fx-text-fill: #212529;" />
                    </children>
                </HBox>
            </children>
        </VBox>

        <!-- Raison actuelle -->
        <VBox spacing="8.0">
            <children>
                <Label text="📝 Raison actuelle" style="-fx-font-weight: 600; -fx-font-size: 14px;" />
                <Label fx:id="lblRaisonActuelle" wrapText="true" style="-fx-background-color: #e9ecef; -fx-padding: 12; -fx-background-radius: 5; -fx-text-fill: #495057; -fx-font-style: italic;" text="-" />
            </children>
        </VBox>

        <!-- Nouvelle raison -->
        <VBox spacing="8.0" VBox.vgrow="ALWAYS">
            <children>
                <Label text="✍️ Nouvelle raison" style="-fx-font-weight: 600; -fx-font-size: 14px;" />
                <Label text="Expliquez pourquoi vous souhaitez suivre cette formation (min. 10 caractères)" style="-fx-font-size: 11px; -fx-text-fill: #666;" />
                <TextArea fx:id="txtNouvelleRaison" prefHeight="100.0" promptText="Ex: Je souhaite approfondir mes connaissances en..." style="-fx-background-radius: 5; -fx-border-color: #ddd; -fx-border-radius: 5;" wrapText="true" VBox.vgrow="ALWAYS" />
            </children>
        </VBox>

        <!-- Buttons -->
        <VBox spacing="12.0">
            <children>
                <Button fx:id="btnModifier" maxWidth="Infinity" onAction="#handleModifier" prefHeight="45.0" style="-fx-background-color: linear-gradient(to right, #667eea 0%, #764ba2 100%); -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 8; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 3);" text="✓ Enregistrer la Modification" />
                <Button fx:id="btnAnnuler" maxWidth="Infinity" onAction="#handleAnnuler" prefHeight="38.0" style="-fx-background-color: transparent; -fx-border-color: #95a5a6; -fx-border-width: 1.5; -fx-text-fill: #7f8c8d; -fx-font-weight: 500; -fx-background-radius: 8; -fx-border-radius: 8; -fx-cursor: hand;" text="✗ Annuler" />
            </children>
        </VBox>
    </children>
</VBox>

