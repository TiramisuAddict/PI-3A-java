<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #f3f4f6;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.employers.admin_sys.demandes_entreprise">

    <children>
        <VBox alignment="TOP_CENTER" spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="30.0">
            <HBox alignment="CENTER_LEFT" spacing="20.0">
                <children>
                    <VBox alignment="CENTER_LEFT" spacing="2.0">
                        <children>
                            <Label text="Demandes d'inscription" textFill="#1e293b">
                                <font><Font name="System Bold" size="26.0" /></font>
                            </Label>
                            <Label text="Gérez les entreprises en attente" textFill="#64748b">
                                <font><Font size="13.0" /></font>
                            </Label>
                        </children>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                </children>
            </HBox>
            <HBox alignment="CENTER" spacing="20.0">
                <children>
                    <!-- Card: Total -->
                    <VBox alignment="CENTER_LEFT" prefHeight="110.0" prefWidth="180.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 8, 0, 0, 4);">
                        <padding><Insets left="20" top="15" bottom="15"/></padding>
                        <children>
                            <Label text="Total" ><font><Font size="14.0" /></font></Label>
                            <Label fx:id="lblTotal" text="0" ><font><Font name="System Bold" size="36.0" /></font></Label>
                        </children>
                    </VBox>

                    <VBox alignment="CENTER_LEFT" prefHeight="110.0" prefWidth="180.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 8, 0, 0, 4);">
                        <padding><Insets left="20" top="15" bottom="15"/></padding>
                        <children>
                            <Label text="En attente" ><font><Font size="14.0" /></font></Label>
                            <Label fx:id="lblEnAttente" text="0" ><font><Font name="System Bold" size="36.0" /></font></Label>
                        </children>
                    </VBox>
                    <VBox alignment="CENTER_LEFT" prefHeight="110.0" prefWidth="180.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 8, 0, 0, 4);">
                        <padding><Insets left="20" top="15" bottom="15"/></padding>
                        <children>
                            <Label text="Acceptées"><font><Font size="14.0" /></font></Label>
                            <Label fx:id="lblAcceptees" text="0"><font><Font name="System Bold" size="36.0" /></font></Label>
                        </children>
                    </VBox>
                    <VBox alignment="CENTER_LEFT" prefHeight="110.0" prefWidth="180.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 8, 0, 0, 4);">
                        <padding><Insets left="20" top="15" bottom="15"/></padding>
                        <children>
                            <Label text="Refusées" ><font><Font size="14.0" /></font></Label>
                            <Label fx:id="lblRefusees" text="0"><font><Font name="System Bold" size="36.0" /></font></Label>
                        </children>
                    </VBox>
                </children>
            </HBox>

            <HBox alignment="CENTER_LEFT">
                <HBox alignment="CENTER_LEFT" prefWidth="350.0" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 8 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 5, 0, 0, 2);">
                    <children>
                        <Label textFill="#94a3b8" />
                        <TextField fx:id="searchField" promptText="Rechercher..." style="-fx-background-color: transparent; -fx-text-fill: #1e293b; -fx-font-size: 13px;" HBox.hgrow="ALWAYS" />
                    </children>
                </HBox>
            </HBox>
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-padding: 0;" VBox.vgrow="ALWAYS">
                <content>
                    <VBox fx:id="demandesContainer" spacing="10.0" style="-fx-padding: 2;">
                    </VBox>
                </content>
            </ScrollPane>

        </VBox>
    </children>
</AnchorPane>