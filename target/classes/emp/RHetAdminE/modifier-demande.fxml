<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.employers.RHetAdminE.ModifierDemandeController">
    <children>
        <ScrollPane fitToWidth="true" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <content>
                <VBox spacing="10.0">
                    <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                    </padding>
                    <children>
                        <!-- Header -->
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Button onAction="#retourListe" text="← Retour" style="-fx-background-color: #95a5a6; -fx-text-fill: white;">
                                    <font><Font name="System Bold" size="12.0" /></font>
                                </Button>
                                <Label fx:id="headerLabel" text="Modifier Demande" textFill="#2c3e50">
                                    <font>
                                        <Font name="System Bold" size="22.0" />
                                    </font>
                                </Label>
                            </children>
                        </HBox>

                        <!-- Main Form -->
                        <TitledPane animated="false" collapsible="false" text="Informations Générales">
                            <content>
                                <GridPane hgap="10.0" vgap="10.0">
                                    <padding>
                                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                                    </padding>
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="150.0" minWidth="120.0" />
                                        <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" />
                                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="150.0" minWidth="120.0" />
                                        <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" />
                                    </columnConstraints>
                                    <children>
                                        <Label text="Titre: *" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                        <VBox GridPane.columnIndex="1" GridPane.rowIndex="0">
                                            <TextField fx:id="titreField" promptText="Entrez le titre" />
                                            <Label fx:id="titreError" text="" style="-fx-text-fill: red; -fx-font-size: 11;" />
                                        </VBox>

                                        <Label text="Catégorie: *" style="-fx-font-weight: bold;" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                                        <VBox GridPane.columnIndex="3" GridPane.rowIndex="0">
                                            <ComboBox fx:id="categorieCombo" maxWidth="1.7976931348623157E308" promptText="Sélectionnez" />
                                            <Label fx:id="categorieError" text="" style="-fx-text-fill: red; -fx-font-size: 11;" />
                                        </VBox>

                                        <Label text="Type Demande: *" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                        <VBox GridPane.columnIndex="1" GridPane.rowIndex="1">
                                            <ComboBox fx:id="typeDemandeCombo" maxWidth="1.7976931348623157E308" promptText="Sélectionnez le type" />
                                            <Label fx:id="typeError" text="" style="-fx-text-fill: red; -fx-font-size: 11;" />
                                        </VBox>

                                        <Label text="Priorité: *" style="-fx-font-weight: bold;" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                                        <VBox GridPane.columnIndex="3" GridPane.rowIndex="1">
                                            <ComboBox fx:id="prioriteCombo" maxWidth="1.7976931348623157E308" promptText="Sélectionnez" />
                                            <Label fx:id="prioriteError" text="" style="-fx-text-fill: red; -fx-font-size: 11;" />
                                        </VBox>

                                        <Label text="Description: *" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                        <VBox GridPane.columnIndex="1" GridPane.columnSpan="3" GridPane.rowIndex="2">
                                            <TextArea fx:id="descriptionArea" prefRowCount="2" promptText="Description" wrapText="true" />
                                            <Label fx:id="descriptionError" text="" style="-fx-text-fill: red; -fx-font-size: 11;" />
                                        </VBox>

                                        <Label text="Statut: *" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                        <VBox GridPane.columnIndex="1" GridPane.rowIndex="3">
                                            <ComboBox fx:id="statusCombo" maxWidth="1.7976931348623157E308" />
                                            <Label fx:id="statusError" text="" style="-fx-text-fill: red; -fx-font-size: 11;" />
                                        </VBox>

                                        <Label text="Date: *" style="-fx-font-weight: bold;" GridPane.columnIndex="2" GridPane.rowIndex="3" />
                                        <VBox GridPane.columnIndex="3" GridPane.rowIndex="3">
                                            <DatePicker fx:id="dateCreationPicker" maxWidth="1.7976931348623157E308" />
                                            <Label fx:id="dateError" text="" style="-fx-text-fill: red; -fx-font-size: 11;" />
                                        </VBox>
                                    </children>
                                </GridPane>
                            </content>
                        </TitledPane>

                        <!-- Dynamic Details -->
                        <TitledPane fx:id="detailsPane" animated="false" collapsible="false" text="Détails Spécifiques">
                            <content>
                                <VBox fx:id="dynamicFieldsContainer" spacing="10.0">
                                    <padding>
                                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                                    </padding>
                                    <children>
                                        <Label text="Sélectionnez un type de demande" style="-fx-text-fill: gray; -fx-font-style: italic;" />
                                    </children>
                                </VBox>
                            </content>
                        </TitledPane>

                        <!-- Submit Button -->
                        <HBox alignment="CENTER" spacing="10.0">
                            <padding>
                                <Insets top="10.0" bottom="10.0" />
                            </padding>
                            <children>
                                <Button onAction="#modifierDemande" prefWidth="200.0" prefHeight="40.0" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="Enregistrer les Modifications">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Button>
                                <Button onAction="#retourListe" prefWidth="150.0" prefHeight="40.0" style="-fx-background-color: #95a5a6; -fx-text-fill: white;" text="Annuler">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Button>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>