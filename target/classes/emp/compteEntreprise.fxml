<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="750.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.employers.compteEntreprise">

    <children>
        <StackPane AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" style="-fx-background-color: #f4f7f6;">
            <padding>
                <Insets top="30" right="30" bottom="30" left="30"/>
            </padding>

            <children>

                <VBox alignment="TOP_CENTER" spacing="12.0"
                      prefWidth="420.0" prefHeight="540.0"
                      maxWidth="420.0" maxHeight="540.0"
                      style="-fx-background-color: white;-fx-background-radius: 16; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.12), 14, 0, 0, 8);">
                    <padding>
                        <Insets top="26" right="24" bottom="26" left="24"/>
                    </padding>
                    <children>
                        <ImageView  fitHeight="200.0" fitWidth="280.0" preserveRatio="true">
                            <image >
                                <Image url="@../icons/main-logo.png"/>
                            </image>
                            <VBox.margin>
                                <Insets bottom="20"/>
                            </VBox.margin>
                        </ImageView>


                        <Label text="Remplissez le formulaire ci dessous" textFill="#6b7280">
                            <font>
                                <Font size="12.0"/>
                            </font>
                            <VBox.margin>
                                <Insets bottom="8"/>
                            </VBox.margin>
                        </Label>
                        <TextField fx:id="nomEField" promptText="Nom de l'entreprise" prefHeight="42.0" maxWidth="1.7976931348623157E308" style="-fx-background-color: #f9fafb; -fx-background-radius: 10;-fx-border-color: #e5e7eb;-fx-border-radius: 10;-fx-padding: 0 14 0 14;-fx-prompt-text-fill: #9ca3af;-fx-focus-color: transparent; -fx-faint-focus-color: transparent;"/>

                        <HBox spacing="12">

                            <TextField fx:id="paysField" promptText="Pays" prefHeight="42.0" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS" style="-fx-background-color: #f9fafb;-fx-background-radius: 10;-fx-border-color: #e5e7eb;-fx-border-radius: 10; -fx-padding: 0 14 0 14;-fx-prompt-text-fill: #9ca3af;-fx-focus-color: transparent;-fx-faint-focus-color: transparent;"/>
                            <TextField fx:id="villeField" promptText="Ville" prefHeight="42.0" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS" style="-fx-background-color: #f9fafb;-fx-background-radius: 10;-fx-border-color: #e5e7eb;-fx-border-radius: 10;-fx-padding: 0 14 0 14;-fx-prompt-text-fill: #9ca3af;-fx-focus-color: transparent;-fx-faint-focus-color: transparent;"/>

                        </HBox>

                        <HBox spacing="12">
                            <TextField fx:id="nomField" promptText="Nom" prefHeight="42.0" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS" style="-fx-background-color: #f9fafb;-fx-background-radius: 10;-fx-border-color: #e5e7eb;-fx-border-radius: 10;-fx-padding: 0 14 0 14;-fx-prompt-text-fill: #9ca3af;-fx-focus-color: transparent;-fx-faint-focus-color: transparent;"/>

                            <TextField fx:id="prenomField" promptText="Prénom" prefHeight="42.0" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS" style="-fx-background-color: #f9fafb;-fx-background-radius: 10;-fx-border-color: #e5e7eb;-fx-border-radius: 10;-fx-padding: 0 14 0 14;-fx-prompt-text-fill: #9ca3af;-fx-focus-color: transparent;-fx-faint-focus-color: transparent;"/>
                        </HBox>

                        <TextField fx:id="e_mailField" promptText="Adresse e-mail" prefHeight="42.0" maxWidth="1.7976931348623157E308" style="-fx-background-color: #f9fafb;-fx-background-radius: 10;-fx-border-color: #e5e7eb;-fx-border-radius: 10;-fx-padding: 0 14 0 14;-fx-prompt-text-fill: #9ca3af;-fx-focus-color: transparent;-fx-faint-focus-color: transparent;"/>

                        <HBox spacing="12">

                            <TextField fx:id="matriculeFiescaleField" promptText="Matricule fiscale" prefHeight="42.0" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS" style="-fx-background-color: #f9fafb;-fx-background-radius: 10;-fx-border-color: #e5e7eb;-fx-border-radius: 10;-fx-padding: 0 14 0 14;-fx-prompt-text-fill: #9ca3af;-fx-focus-color: transparent;-fx-faint-focus-color: transparent;"/>
                            <TextField fx:id="telephoneField" promptText="Téléphone" prefHeight="42.0" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS" style="-fx-background-color: #f9fafb;-fx-background-radius: 10;-fx-border-color: #e5e7eb;-fx-border-radius: 10;-fx-padding: 0 14 0 14;-fx-prompt-text-fill: #9ca3af;-fx-focus-color: transparent;-fx-faint-focus-color: transparent;"/>
                        </HBox>

                        <Label fx:id="msgError" prefHeight="18.0" alignment="CENTER"
                               maxWidth="1.7976931348623157E308"
                               textFill="#ef4444"/>

                        <Button
                                onAction="#ajouterCompteEntreprise" text="ENVOYER LA DEMANDE" prefHeight="42.0" maxWidth="1.7976931348623157E308" mnemonicParsing="false" style="-fx-background-color: #4A5DEF;-fx-text-fill: white;-fx-font-weight: bold;-fx-background-radius: 10;-fx-cursor: hand;-fx-focus-color: transparent;-fx-faint-focus-color: transparent;"/>

                        <HBox alignment="CENTER" spacing="6">
                            <VBox.margin>
                                <Insets top="15"/>
                            </VBox.margin>
                            <Label text="vous avez déja un compte?" textFill="#000000">
                                <font>
                                    <Font size="11.0"/>
                                </font>
                            </Label>
                            <Hyperlink onAction="#naviguerVersLogin" text="connecter" underline="false" style="-fx-text-fill: #4A5DEF;">
                                <font>
                                    <Font size="11.0"/>
                                </font>
                            </Hyperlink>
                        </HBox>

                    </children>
                </VBox>

            </children>
        </StackPane>

    </children>
</AnchorPane>