<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="1100.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.demandes.DemandesController">
    <children>
        <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <tabs>
                <!-- ========================================== -->
                <!-- TAB 1: GESTION DES DEMANDES -->
                <!-- ========================================== -->
                <Tab text="📋 Demandes" closable="false">
                    <VBox spacing="10.0">
                        <padding>
                            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                        </padding>
                        <children>
                            <!-- Title -->
                            <Label text="Gestion des Demandes" textFill="#2c3e50">
                                <font>
                                    <Font name="System Bold" size="24.0" />
                                </font>
                            </Label>

                            <!-- Top Bar -->
                            <HBox alignment="CENTER_LEFT" spacing="10.0">
                                <padding>
                                    <Insets top="5.0" bottom="5.0" />
                                </padding>
                                <children>
                                    <Label text="🔍" style="-fx-font-size: 16;" />
                                    <TextField fx:id="rechercheField" prefWidth="350.0" promptText="Rechercher par titre..." />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Button onAction="#ouvrirAjouter" prefWidth="140.0" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="+ Ajouter">
                                        <font><Font name="System Bold" size="13.0" /></font>
                                    </Button>
                                </children>
                            </HBox>

                            <!-- Main Content: Table + Details Panel -->
                            <SplitPane fx:id="splitPane" dividerPositions="0.6" VBox.vgrow="ALWAYS">
                                <items>
                                    <!-- Left: Table -->
                                    <VBox spacing="5.0">
                                        <padding>
                                            <Insets right="5.0" />
                                        </padding>
                                        <children>
                                            <TableView fx:id="demandesTable" VBox.vgrow="ALWAYS">
                                                <columns>
                                                    <TableColumn fx:id="titreCol" prefWidth="130.0" text="Titre" />
                                                    <TableColumn fx:id="categorieCol" prefWidth="90.0" text="Catégorie" />
                                                    <TableColumn fx:id="typeCol" prefWidth="90.0" text="Type" />
                                                    <TableColumn fx:id="prioriteCol" prefWidth="75.0" text="Priorité" />
                                                    <TableColumn fx:id="statusCol" prefWidth="75.0" text="Statut" />
                                                    <TableColumn fx:id="dateCol" prefWidth="90.0" text="Date" />
                                                    <TableColumn fx:id="actionsCol" prefWidth="170.0" text="Actions" />
                                                </columns>
                                            </TableView>
                                        </children>
                                    </VBox>

                                    <!-- Right: Details Panel -->
                                    <ScrollPane fitToWidth="true">
                                        <content>
                                            <VBox fx:id="detailsPanel" spacing="10.0" style="-fx-background-color: #f8f9fa;">
                                                <padding>
                                                    <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                                                </padding>
                                                <children>
                                                    <VBox fx:id="placeholderBox" alignment="CENTER" spacing="10.0" style="-fx-padding: 50;">
                                                        <children>
                                                            <Label text="📋" style="-fx-font-size: 48;" />
                                                            <Label text="Sélectionnez une demande" style="-fx-font-size: 16; -fx-text-fill: #999;" />
                                                            <Label text="Cliquez sur une ligne pour voir les détails" style="-fx-font-size: 12; -fx-text-fill: #bbb;" />
                                                        </children>
                                                    </VBox>

                                                    <VBox fx:id="detailsContent" spacing="10.0" visible="false" managed="false">
                                                        <children>
                                                            <HBox alignment="CENTER_LEFT" spacing="10.0">
                                                                <children>
                                                                    <Label fx:id="detailTitreLabel" text="" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                                                                </children>
                                                            </HBox>
                                                            <Separator />
                                                            <GridPane hgap="10.0" vgap="8.0">
                                                                <columnConstraints>
                                                                    <ColumnConstraints minWidth="100.0" />
                                                                    <ColumnConstraints hgrow="ALWAYS" />
                                                                </columnConstraints>
                                                                <children>
                                                                    <Label text="Catégorie:" style="-fx-font-weight: bold; -fx-text-fill: #666;" GridPane.rowIndex="0" />
                                                                    <Label fx:id="detailCategorieLabel" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                                                    <Label text="Type:" style="-fx-font-weight: bold; -fx-text-fill: #666;" GridPane.rowIndex="1" />
                                                                    <Label fx:id="detailTypeLabel" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                                                    <Label text="Priorité:" style="-fx-font-weight: bold; -fx-text-fill: #666;" GridPane.rowIndex="2" />
                                                                    <Label fx:id="detailPrioriteLabel" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                                                    <Label text="Statut:" style="-fx-font-weight: bold; -fx-text-fill: #666;" GridPane.rowIndex="3" />
                                                                    <Label fx:id="detailStatusLabel" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                                                    <Label text="Date:" style="-fx-font-weight: bold; -fx-text-fill: #666;" GridPane.rowIndex="4" />
                                                                    <Label fx:id="detailDateLabel" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                                                                </children>
                                                            </GridPane>
                                                            <Separator />
                                                            <Label text="Description:" style="-fx-font-weight: bold; -fx-text-fill: #666;" />
                                                            <Label fx:id="detailDescriptionLabel" wrapText="true" style="-fx-padding: 5 10; -fx-background-color: white; -fx-background-radius: 5;" />
                                                            <Separator />
                                                            <Label text="Détails Spécifiques:" style="-fx-font-weight: bold; -fx-text-fill: #666;" />
                                                            <VBox fx:id="detailSpecificContainer" spacing="5.0" style="-fx-padding: 5 10; -fx-background-color: white; -fx-background-radius: 5;" />
                                                            <Separator />
                                                            <HBox alignment="CENTER_LEFT" spacing="10.0">
                                                                <children>
                                                                    <Label text="Historique:" style="-fx-font-weight: bold; -fx-text-fill: #666; -fx-font-size: 14;" />
                                                                    <Region HBox.hgrow="ALWAYS" />
                                                                    <Button fx:id="avancerBtn" onAction="#ouvrirAvancer" text="⚡ Avancer Statut" style="-fx-background-color: #f39c12; -fx-text-fill: white;">
                                                                        <font><Font name="System Bold" size="12.0" /></font>
                                                                    </Button>
                                                                </children>
                                                            </HBox>
                                                            <VBox fx:id="historiqueContainer" spacing="8.0" />
                                                        </children>
                                                    </VBox>
                                                </children>
                                            </VBox>
                                        </content>
                                    </ScrollPane>
                                </items>
                            </SplitPane>
                        </children>
                    </VBox>
                </Tab>

                <!-- ========================================== -->
                <!-- TAB 2: STATISTIQUES -->
                <!-- ========================================== -->
                <Tab text="📊 Statistiques" closable="false">
                    <ScrollPane fitToWidth="true" style="-fx-background-color: #f8f9fa;">
                        <content>
                            <VBox spacing="25.0" style="-fx-padding: 30;">
                                <children>
                                    <!-- Header -->
                                    <HBox alignment="CENTER_LEFT" spacing="15.0">
                                        <children>
                                            <Label text="📊 Statistiques des Demandes" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                                            <Region HBox.hgrow="ALWAYS" />
                                            <Button onAction="#refreshStatistiques" text="🔄 Actualiser" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-padding: 8 16; -fx-font-weight: bold;" />
                                        </children>
                                    </HBox>

                                    <!-- Big Stats Cards -->
                                    <HBox spacing="20.0" alignment="CENTER">
                                        <children>
                                            <VBox alignment="CENTER" spacing="10.0" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                                                <children>
                                                    <Label text="📋" style="-fx-font-size: 36;" />
                                                    <Label fx:id="lblTotalDemandes" text="0" style="-fx-font-size: 48; -fx-font-weight: bold; -fx-text-fill: #3498db;" />
                                                    <Label text="Total Demandes" style="-fx-font-size: 14; -fx-text-fill: #7f8c8d;" />
                                                </children>
                                            </VBox>
                                            <VBox alignment="CENTER" spacing="10.0" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                                                <children>
                                                    <Label text="📝" style="-fx-font-size: 36;" />
                                                    <Label fx:id="lblTotalHistorique" text="0" style="-fx-font-size: 48; -fx-font-weight: bold; -fx-text-fill: #e74c3c;" />
                                                    <Label text="Changements Statut" style="-fx-font-size: 14; -fx-text-fill: #7f8c8d;" />
                                                </children>
                                            </VBox>
                                            <VBox alignment="CENTER" spacing="10.0" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                                                <children>
                                                    <Label text="✅" style="-fx-font-size: 36;" />
                                                    <Label fx:id="lblDemandesResolues" text="0" style="-fx-font-size: 48; -fx-font-weight: bold; -fx-text-fill: #27ae60;" />
                                                    <Label text="Résolues" style="-fx-font-size: 14; -fx-text-fill: #7f8c8d;" />
                                                </children>
                                            </VBox>
                                        </children>
                                    </HBox>

                                    <Separator />

                                    <!-- Par Statut -->
                                    <Label text="📌 Par Statut" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                                    <HBox fx:id="statutStatsContainer" spacing="15.0" alignment="CENTER" />

                                    <Separator />

                                    <!-- Par Priorité -->
                                    <Label text="🔥 Par Priorité" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                                    <HBox fx:id="prioriteStatsContainer" spacing="15.0" alignment="CENTER" />

                                    <Separator />

                                    <!-- Par Type -->
                                    <Label text="📂 Par Type de Demande" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                                    <HBox fx:id="typeStatsContainer" spacing="15.0" alignment="CENTER" />

                                    <Separator />

                                    <!-- Par Catégorie -->
                                    <Label text="🏷️ Par Catégorie" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                                    <HBox fx:id="categorieStatsContainer" spacing="15.0" alignment="CENTER" />

                                    <Separator />

                                    <!-- Par Acteur -->
                                    <Label text="👤 Par Acteur (Historique)" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                                    <HBox fx:id="acteurStatsContainer" spacing="15.0" alignment="CENTER" />
                                </children>
                            </VBox>
                        </content>
                    </ScrollPane>
                </Tab>
            </tabs>
        </TabPane>
    </children>
</AnchorPane>