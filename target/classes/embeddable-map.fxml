<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.map.EmbeddableMapController"
      style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15;
             -fx-border-color: #e0e0e0; -fx-border-radius: 10;">
    <children>
        <!-- Search Section -->
        <VBox spacing="5">
            <children>
                <Label text="📍 Sélectionner un emplacement"
                       style="-fx-font-weight: bold; -fx-font-size: 13; -fx-text-fill: #2c3e50;" />

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <children>
                        <TextField fx:id="searchField"
                                   HBox.hgrow="ALWAYS"
                                   prefHeight="38"
                                   promptText="🔍 Rechercher une adresse..."
                                   style="-fx-background-radius: 8; -fx-border-radius: 8;
                                          -fx-border-color: #ddd; -fx-font-size: 12;" />
                        <ProgressIndicator fx:id="searchProgress"
                                           prefWidth="20" prefHeight="20"
                                           visible="false" />
                    </children>
                </HBox>

                <!-- Search Results -->
                <VBox fx:id="searchResultsContainer" visible="false" managed="false"
                      style="-fx-background-color: white; -fx-background-radius: 10;
                             -fx-border-radius: 10; -fx-border-color: #e0e0e0;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 10, 0, 0, 3);">
                    <padding><Insets topRightBottomLeft="5" /></padding>
                    <children>
                        <Label text="Résultats"
                               style="-fx-font-size: 10; -fx-text-fill: #999; -fx-padding: 5 10;" />
                        <ListView fx:id="searchResultsList"
                                  prefHeight="250" maxHeight="300"
                                  style="-fx-background-color: transparent;" />
                    </children>
                </VBox>
            </children>
        </VBox>

        <!-- Selected Location Display -->
        <Label fx:id="selectedLocationLabel"
               text="Aucun emplacement sélectionné"
               wrapText="true"
               style="-fx-font-size: 11; -fx-text-fill: #7f8c8d; -fx-padding: 5 0;" />

        <!-- Map -->
        <WebView fx:id="mapWebView" prefHeight="300" VBox.vgrow="ALWAYS" />
    </children>
</VBox>