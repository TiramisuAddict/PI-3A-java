<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>

<StackPane prefHeight="800.0" prefWidth="1200.0" style="-fx-background-color: -color-accent-0;"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.offres.CandidatureController">

   <!-- POSTULER CARD -->
   <VBox fx:id="postulerCard" alignment="TOP_CENTER" maxHeight="620.0" maxWidth="650.0" minHeight="620.0" minWidth="650.0" prefHeight="620.0" prefWidth="650.0" spacing="20.0" style="-fx-background-color: -color-bg-default; -fx-background-radius: 15;" StackPane.alignment="CENTER">
      <padding>
         <Insets bottom="40.0" left="60.0" right="60.0" top="40.0" />
      </padding>
      <effect>
         <DropShadow height="30.0" radius="14.5" width="30.0">
            <color>
               <Color opacity="0.1" />
            </color>
         </DropShadow>
      </effect>
      <ImageView fitHeight="40.0" preserveRatio="true">
         <VBox.margin>
            <Insets bottom="20.0"/>
         </VBox.margin>
         <Image url="@images/wordMarkLogo.png"/>
      </ImageView>
      <VBox spacing="12.0">
         <HBox alignment="CENTER" spacing="80.0">
            <Label fx:id="lblStepOffre" style="-fx-font-weight: bold; -fx-text-fill: -color-fg-default;"
                   text="Offre"/>
            <Label fx:id="lblStepInfo" style="-fx-font-weight: bold; -fx-text-fill: -color-fg-muted;"
                   text="Informations"/>
            <Label fx:id="lblStepEnvoi" style="-fx-font-weight: bold; -fx-text-fill: -color-fg-muted;"
                   text="Envoi"/>
         </HBox>
         <ProgressBar fx:id="progressBar" maxWidth="Infinity" minHeight="8.0" prefHeight="8.0" progress="0.33"
                      style="-fx-accent: -color-accent-emphasis; -fx-control-inner-background: -color-base-1;">
            <VBox.margin>
               <Insets top="4.0"/>
            </VBox.margin>
         </ProgressBar>
      </VBox>
      <StackPane fx:id="contentStack" VBox.vgrow="ALWAYS">
         <VBox fx:id="step1View" spacing="20.0">
            <HBox spacing="10.0">
               <TextField fx:id="txtCodeOffre" prefHeight="45.0" promptText="Code Offre" style="-fx-border-color: -color-border-default; -fx-border-radius: 5;" HBox.hgrow="ALWAYS" />
               <Button onAction="#verifyCodeCandidature" prefHeight="45.0" prefWidth="100.0" style="-fx-background-color: -color-accent-emphasis; -fx-text-fill: -color-fg-emphasis; -fx-font-weight: bold; -fx-cursor: hand;" text="Verifier" />
            </HBox>
            <HBox fx:id="badgeValid" managed="false" visible="false">
               <Label style="-fx-background-color: -color-success-emphasis; -fx-text-fill: -color-fg-emphasis; -fx-padding: 5 15; -fx-background-radius: 5; -fx-font-weight: bold;" text="✔ Offre vérifiée !" />
            </HBox>
            <HBox fx:id="badgeInvalide" managed="false" visible="false">
               <Label style="-fx-background-color: -color-danger-emphasis; -fx-text-fill: -color-fg-emphasis; -fx-padding: 5 15; -fx-background-radius: 5; -fx-font-weight: bold;" text="✖ Code invalide !" />
            </HBox>
            <VBox fx:id="offerDetailsBox" managed="false" spacing="10.0" style="-fx-background-color: -color-accent-emphasis; -fx-padding: 15; -fx-background-radius: 10;" visible="false">
               <Label style="-fx-font-weight: bold; -fx-font-size: 14; -fx-text-fill: -color-fg-emphasis;" fx:id="detailNomEnterprise"/>
               <Label style="-fx-text-fill: -color-fg-emphasis;" fx:id="detailPoste" />
               <Label style="-fx-text-fill: -color-fg-emphasis;" fx:id="detailTypeContrat"/>
            </VBox>
            <Label alignment="CENTER" maxWidth="Infinity" style="-fx-background-color: -color-warning-emphasis; -fx-text-fill: -color-fg-emphasis; -fx-padding: 12; -fx-background-radius: 5; -fx-font-weight: bold; -fx-font-size: 11;" text="Vos données sont confidentielles et accessibles uniquement aux RH !" />
            <Region VBox.vgrow="ALWAYS" />
            <Button fx:id="btnNextToStep2" disable="true" maxWidth="Infinity" onAction="#showStep2" prefHeight="50.0" style="-fx-background-color: -color-accent-emphasis; -fx-text-fill: -color-fg-emphasis; -fx-font-weight: bold; -fx-font-size: 15; -fx-cursor: hand;" text="Suivant" />
         </VBox>
         <VBox fx:id="step2View" managed="false" spacing="20.0" visible="false">
            <GridPane hgap="15.0" vgap="15.0">
               <TextField fx:id="txtNom" prefHeight="45.0" promptText="Nom *" GridPane.columnIndex="0" />
               <TextField fx:id="txtPrenom" prefHeight="45.0" promptText="Prénom *" GridPane.columnIndex="1" />
               <TextField fx:id="txtTel" prefHeight="45.0" promptText="Num Tél *" GridPane.rowIndex="1" />
               <TextField fx:id="txtEmail" prefHeight="45.0" promptText="Email *" GridPane.columnIndex="1" GridPane.rowIndex="1" />
               <columnConstraints>
                  <ColumnConstraints hgrow="ALWAYS" />
                  <ColumnConstraints hgrow="ALWAYS" />
               </columnConstraints>
               <rowConstraints>
                  <RowConstraints />
                  <RowConstraints />
               </rowConstraints>
            </GridPane>
            <Button fx:id="btnCV" maxWidth="Infinity" onAction="#pickCV" prefHeight="45.0" style="-fx-background-color: -color-bg-default; -fx-border-color: -color-border-default; -fx-border-radius: 5; -fx-cursor: hand;" text="📎 Joindre CV (PDF) *" />
            <Button fx:id="btnLettre" maxWidth="Infinity" onAction="#pickLettre" prefHeight="45.0" style="-fx-background-color: -color-bg-default; -fx-border-color: -color-border-default; -fx-border-radius: 5; -fx-cursor: hand;" text="📎 Lettre de Motivation (PDF) *" />
            <Region VBox.vgrow="ALWAYS" />
            <HBox spacing="15.0">
               <Button onAction="#showStep1" prefHeight="50.0" prefWidth="150.0" style="-fx-cursor: hand;" text="Retour" />
               <Button maxWidth="Infinity" onAction="#showStep3" prefHeight="50.0" style="-fx-background-color: -color-accent-emphasis; -fx-text-fill: -color-fg-emphasis; -fx-font-weight: bold; -fx-cursor: hand;" text="Postuler" HBox.hgrow="ALWAYS" />
            </HBox>
         </VBox>
         <VBox fx:id="step3View" alignment="CENTER" managed="false" spacing="25.0" visible="false">
            <Label style="-fx-font-size: 80; -fx-text-fill: -color-success-emphasis;" text="✔" />
            <Label style="-fx-font-weight: bold; -fx-font-size: 22; -fx-text-fill: -color-fg-default;" text="Merci pour votre candidature !" />
            <Label style="-fx-text-fill: -color-fg-muted;" text="Veuillez conserver ce code pour suivre l'état du dossier :" />
            <Label fx:id="lblTrackingCode" style="-fx-background-color: -color-accent-subtle; -fx-padding: 15 40; -fx-text-fill: -color-accent-fg; -fx-font-weight: bold; -fx-font-size: 20; -fx-background-radius: 8;" text="MOM-882736" />
            <Region prefHeight="20" />
         </VBox>
      </StackPane>
      <HBox alignment="CENTER" spacing="5.0">
         <Label style="-fx-text-fill: -color-fg-muted;" text="Avez-vous déjà postulé ?" />
         <Hyperlink onAction="#handleSuivi" style="-fx-text-fill: -color-accent-fg; -fx-underline: false;" text="Suivre votre candidature" />
      </HBox>
   </VBox>
   <!-- SUIVRE CARD -->
   <VBox fx:id="suivreCard" alignment="TOP_CENTER" maxHeight="620.0" maxWidth="650.0" minHeight="620.0" minWidth="650.0" prefHeight="620.0" prefWidth="650.0" spacing="20.0" style="-fx-background-color: -color-bg-default; -fx-background-radius: 15;" visible="false">
      <padding>
         <Insets bottom="40.0" left="60.0" right="60.0" top="40.0" />
      </padding>
      <effect>
         <DropShadow blurType="THREE_PASS_BOX" height="30.0" radius="14.5" width="30.0">
            <color>
               <Color opacity="0.1" />
            </color>
         </DropShadow>
      </effect>
      <ImageView fitHeight="40.0" preserveRatio="true">
         <image>
            <Image url="@images/wordMarkLogo.png" />
         </image>
         <VBox.margin>
            <Insets bottom="20.0" />
         </VBox.margin>
      </ImageView>
      <StackPane VBox.vgrow="ALWAYS">
         <VBox spacing="20.0">
            <HBox spacing="10.0">
               <TextField prefHeight="45.0" promptText="Code Candidature" style="-fx-border-color: -color-border-default; -fx-border-radius: 5;" HBox.hgrow="ALWAYS" />
               <Button onAction="#verifyCodeCandidature" prefHeight="45.0" prefWidth="100.0" style="-fx-background-color: -color-accent-emphasis; -fx-text-fill: -color-fg-emphasis; -fx-font-weight: bold; -fx-cursor: hand;" text="Verifier" />
            </HBox>
            <VBox fx:id="suivreCandidature" managed="false" spacing="10.0" style="-fx-background-color: -color-accent-emphasis; -fx-padding: 15; -fx-background-radius: 10;" visible="false" />
            <Region VBox.vgrow="ALWAYS" />
            <Button onAction="#verifyCodeCandidature" prefHeight="46.0" prefWidth="662.0" style="-fx-background-color: -color-accent-emphasis; -fx-text-fill: -color-fg-emphasis; -fx-font-weight: bold; -fx-cursor: hand;" text="Verifier" />
         </VBox>
      </StackPane>
      <HBox alignment="CENTER" spacing="5.0">
         <Label style="-fx-text-fill: -color-fg-muted;" text="Vous voulez" />
         <Hyperlink onAction="#handlePost" style="-fx-text-fill: -color-accent-fg; -fx-underline: false;" text="postuler ?" />
      </HBox>
   </VBox>
</StackPane>