<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="1100.0" xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.demandes.AjouterDemandeEmployeController">
    <children>
        <ScrollPane fitToWidth="true" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <content>
                <VBox spacing="15.0" style="-fx-padding: 30;">
                    <children>
                        <!-- Header -->
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                            <children>
                                <Button onAction="#retourListe" text="← Retour"
                                        style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-cursor: hand;">
                                    <font><Font name="System Bold" size="13.0" /></font>
                                </Button>
                                <Label text="📝 Nouvelle Demande"
                                       style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                            </children>
                        </HBox>

                        <Separator />

                        <!-- Form -->
                        <VBox spacing="20.0" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
                            <children>
                                <!-- Titre -->
                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Titre *" style="-fx-font-weight: bold; -fx-text-fill: #555;" />
                                        <TextField fx:id="titreField" promptText="Titre de la demande" prefWidth="500.0" />
                                        <Label fx:id="titreError" text="" style="-fx-text-fill: red; -fx-font-size: 11;" />
                                    </children>
                                </VBox>

                                <!-- Catégorie + Type -->
                                <HBox spacing="20.0">
                                    <children>
                                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Catégorie *" style="-fx-font-weight: bold; -fx-text-fill: #555;" />
                                                <ComboBox fx:id="categorieCombo" maxWidth="Infinity" promptText="Sélectionner..." />
                                                <Label fx:id="categorieError" text="" style="-fx-text-fill: red; -fx-font-size: 11;" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Type de demande *" style="-fx-font-weight: bold; -fx-text-fill: #555;" />
                                                <ComboBox fx:id="typeDemandeCombo" maxWidth="Infinity" promptText="Sélectionner..." />
                                                <Label fx:id="typeError" text="" style="-fx-text-fill: red; -fx-font-size: 11;" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <!-- Priorité + Date -->
                                <HBox spacing="20.0">
                                    <children>
                                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Priorité *" style="-fx-font-weight: bold; -fx-text-fill: #555;" />
                                                <ComboBox fx:id="prioriteCombo" maxWidth="Infinity" promptText="Sélectionner..." />
                                                <Label fx:id="prioriteError" text="" style="-fx-text-fill: red; -fx-font-size: 11;" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Date de création *" style="-fx-font-weight: bold; -fx-text-fill: #555;" />
                                                <DatePicker fx:id="dateCreationPicker" maxWidth="Infinity" />
                                                <Label fx:id="dateError" text="" style="-fx-text-fill: red; -fx-font-size: 11;" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <!-- Status info (read-only) -->
                                <HBox spacing="10.0" alignment="CENTER_LEFT"
                                      style="-fx-padding: 10; -fx-background-color: #ebf5fb; -fx-background-radius: 8;">
                                    <children>
                                        <Label text="ℹ️" style="-fx-font-size: 16;" />
                                        <Label text="Statut initial :"
                                               style="-fx-font-weight: bold; -fx-text-fill: #555;" />
                                        <Label text="Nouvelle"
                                               style="-fx-text-fill: #3498db; -fx-font-weight: bold; -fx-font-size: 14; -fx-padding: 3 10; -fx-background-color: #d4edfc; -fx-background-radius: 10;" />
                                        <Label text="(automatique)"
                                               style="-fx-text-fill: #999; -fx-font-style: italic;" />
                                    </children>
                                </HBox>

                                <!-- Description -->
                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Description *" style="-fx-font-weight: bold; -fx-text-fill: #555;" />
                                        <TextArea fx:id="descriptionArea" promptText="Décrivez votre demande en détail..."
                                                  prefRowCount="4" wrapText="true" />
                                        <Label fx:id="descriptionError" text="" style="-fx-text-fill: red; -fx-font-size: 11;" />
                                    </children>
                                </VBox>

                                <!-- Dynamic Fields -->
                                <TitledPane fx:id="detailsPane" text="Détails Spécifiques" expanded="true"
                                            collapsible="true">
                                    <content>
                                        <VBox fx:id="dynamicFieldsContainer" spacing="10.0" style="-fx-padding: 10;">
                                            <children>
                                                <Label text="Sélectionnez un type de demande"
                                                       style="-fx-text-fill: gray; -fx-font-style: italic;" />
                                            </children>
                                        </VBox>
                                    </content>
                                </TitledPane>
                            </children>
                        </VBox>

                        <!-- Buttons -->
                        <HBox spacing="15.0" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
                            <children>
                                <Button onAction="#reinitialiserFormulaire" text="🔄 Réinitialiser" prefWidth="140.0"
                                        style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-cursor: hand;">
                                    <font><Font name="System Bold" size="13.0" /></font>
                                </Button>
                                <Button onAction="#ajouterDemande" text="✅ Soumettre" prefWidth="140.0"
                                        style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-cursor: hand;">
                                    <font><Font name="System Bold" size="13.0" /></font>
                                </Button>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>