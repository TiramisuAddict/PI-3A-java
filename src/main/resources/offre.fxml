<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

    <HBox
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="controller.offres.OffreController">
    <!-- LEFT: MAIN DASHBOARD -->
    <VBox spacing="25.0" HBox.hgrow="ALWAYS">
        <padding>
            <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
        </padding>
        <!-- HEADER -->
        <HBox alignment="CENTER_LEFT" spacing="15.0">
            <VBox HBox.hgrow="ALWAYS">
                <Label style="-fx-font-weight: bold; -fx-font-size: 24px;" text="Dashboard des Offres" />
                <Label text="Visualisez et gérez vos opportunités de recrutement" textFill="#6e6e6e" />
            </VBox>
            <Button layoutX="480.0" layoutY="20.0" mnemonicParsing="false" onAction="#handleNewOffer" prefHeight="35.0" styleClass="accent" text="+ Créer une Offre" />
        </HBox>
        <FlowPane fx:id="StatisticsPane" prefHeight="100.0" prefWidth="608.0">
            <VBox prefWidth="180.0" style="-fx-background-color: -color-bg-subtle; -fx-background-radius: 5; -fx-padding: 15; -fx-border-color: -color-border-muted; -fx-border-radius: 5;">
                <Label text="Total" textFill="#868686" />
                <Label fx:id="lblTotal21" style="-fx-font-size: 18; -fx-font-weight: bold;" text="0" />
                <opaqueInsets>
                    <Insets />
                </opaqueInsets>
                <FlowPane.margin>
                    <Insets left="10.0" right="10.0" top="20.0" />
                </FlowPane.margin>
            </VBox>
            <VBox layoutX="221.0" layoutY="10.0" prefWidth="180.0" style="-fx-background-color: -color-bg-subtle; -fx-background-radius: 5; -fx-padding: 15; -fx-border-color: -color-border-muted; -fx-border-radius: 5;">
                <Label text="Total" textFill="#868686" />
                <Label fx:id="lblTotal211" style="-fx-font-size: 22; -fx-font-weight: bold;" text="0" />
                <opaqueInsets>
                    <Insets />
                </opaqueInsets>
                <FlowPane.margin>
                    <Insets left="10.0" right="10.0" top="20.0" />
                </FlowPane.margin>
            </VBox>
            <VBox layoutX="422.0" layoutY="10.0" prefWidth="180.0" style="-fx-background-color: -color-bg-subtle; -fx-background-radius: 5; -fx-padding: 15; -fx-border-color: -color-border-muted; -fx-border-radius: 5;">
                <Label text="Total" textFill="#868686" />
                <Label fx:id="lblTotal2111" style="-fx-font-size: 22; -fx-font-weight: bold;" text="0" />
                <opaqueInsets>
                    <Insets />
                </opaqueInsets>
                <FlowPane.margin>
                    <Insets left="10.0" right="10.0" top="20.0" />
                </FlowPane.margin>
            </VBox>
            <VBox.margin>
                <Insets />
            </VBox.margin>
            <padding>
                <Insets top="-15.0" />
            </padding>
        </FlowPane>
        <!-- SEARCH BAR -->
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <TextField fx:id="txtSearch" prefHeight="35.0" prefWidth="350.0" promptText="Rechercher par titre ou code..." />
            <Region HBox.hgrow="ALWAYS" />
            <ComboBox fx:id="filterType" prefHeight="35.0" promptText="Type de contrat" />
        </HBox>
        <!-- SCROLLABLE LIST OF CARDS -->
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
            <content>
                <VBox fx:id="offersContainer" spacing="12.0">
                    <padding>
                        <Insets right="10.0" />
                    </padding>
                    <!-- Cards will be injected here via Java -->
                </VBox>
            </content>
        </ScrollPane>
    </VBox>
    <!-- FORM PANNEL -->
    <VBox prefWidth="350.0" spacing="20.0"
          style="-fx-background-color: -color-base-0; -fx-border-color: -color-border-muted; -fx-border-width: 0 0 0 1;">
        <padding>
            <Insets bottom="25.0" left="25.0" right="25.0" top="25.0"/>
        </padding>
        <Label style="-fx-font-weight: bold; -fx-font-size: 18px;" text="Détails de l'Offre"/>
        <Separator/>
        <VBox spacing="15.0" VBox.vgrow="ALWAYS">
            <VBox spacing="5.0">
                <Label text="Titre du poste"/>
                <TextField fx:id="txtTitre" promptText="Ex: Software Engineer"/>
            </VBox>
            <VBox spacing="5.0">
                <Label text="Code de l'offre"/>
                <HBox prefWidth="309.0" spacing="15.0">
                    <TextField fx:id="txtCode" disable="true" HBox.hgrow="ALWAYS"/>
                    <Button fx:id="btnCode" mnemonicParsing="false" onAction="#generateCodeOffer"
                            prefHeight="35.0" styleClass="accent" text="Générer"/>
                </HBox>
            </VBox>
            <VBox spacing="5.0">
                <Label text="Type de contrat"/>
                <ComboBox fx:id="comboType" maxWidth="Infinity"/>
            </VBox>
            <VBox spacing="5.0">
                <Label text="Date limite"/>
                <DatePicker fx:id="dpDate" maxWidth="Infinity"/>
            </VBox>
            <VBox spacing="5.0">
                <Label text="État de l'offre"/>
                <ComboBox fx:id="comboEtat" maxWidth="Infinity"/>
            </VBox>
        </VBox>
        <VBox spacing="10.0">
            <HBox spacing="15.0" HBox.hgrow="ALWAYS">
                <Button fx:id="btnSave" maxWidth="Infinity" onAction="#handleSave" prefHeight="40.0"
                        styleClass="accent" text="Ajouter" HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnUpdate" layoutX="10.0" layoutY="10.0" maxWidth="Infinity"
                        onAction="#handleUpdate" prefHeight="40.0" styleClass="accent" text="Modifier"
                        HBox.hgrow="ALWAYS"/>
            </HBox>
            <Button fx:id="btnDelete" maxWidth="Infinity" onAction="#handleDelete" prefHeight="40.0"
                    styleClass="danger, outline" text="Supprimer"/>
        </VBox>
    </VBox>
</HBox>