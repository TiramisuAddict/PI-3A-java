<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="weatherContainer" spacing="12" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.widgets.WeatherWidgetController"
      style="-fx-background-color: linear-gradient(to bottom right, #667eea, #764ba2);
             -fx-background-radius: 15; -fx-padding: 20;">

    <!-- ══ HEADER ══ -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <ImageView fx:id="weatherIcon" fitWidth="60" fitHeight="60" preserveRatio="true"/>
        <VBox spacing="2">
            <Label fx:id="temperatureLabel" text="--°C"
                   style="-fx-text-fill: white; -fx-font-size: 32; -fx-font-weight: bold;"/>
            <Label fx:id="descriptionLabel" text="Chargement..."
                   style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14;"/>
            <Label fx:id="cityLabel" text="--"
                   style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="🔄" onAction="#refreshWeather"
                style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white;
                       -fx-font-size: 16; -fx-cursor: hand; -fx-background-radius: 20;
                       -fx-min-width: 35; -fx-min-height: 35;"/>
    </HBox>

    <!-- ══ CURRENT DETAILS ══ -->
    <HBox spacing="20" alignment="CENTER">
        <VBox alignment="CENTER" spacing="2">
            <Label text="💧 Humidité" style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 10;"/>
            <Label fx:id="humidityLabel" text="--%"
                   style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14;"/>
        </VBox>
        <VBox alignment="CENTER" spacing="2">
            <Label text="💨 Vent" style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 10;"/>
            <Label fx:id="windLabel" text="-- m/s"
                   style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14;"/>
        </VBox>
        <VBox alignment="CENTER" spacing="2">
            <Label text="🌡️ Ressenti" style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 10;"/>
            <Label fx:id="feelsLikeLabel" text="--°C"
                   style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14;"/>
        </VBox>
    </HBox>

    <!-- ══ SEPARATOR ══ -->
    <Separator style="-fx-background-color: rgba(255,255,255,0.2);"/>

    <!-- ══ WEEKLY FORECAST TITLE ══ -->
    <Label text="📅 Prévisions de la semaine"
           style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14;"/>

    <!-- ══ WEEKLY FORECAST CARDS ══ -->
    <HBox fx:id="forecastContainer" spacing="8" alignment="CENTER">
        <!-- Filled dynamically by controller -->
        <Label text="Chargement des prévisions..."
               style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 12;"/>
    </HBox>

    <!-- ══ RECOMMENDATION ══ -->
    <Label fx:id="recommendationLabel" text="..."
           style="-fx-text-fill: white; -fx-font-size: 11;
                  -fx-background-color: rgba(255,255,255,0.15);
                  -fx-background-radius: 8; -fx-padding: 10;"
           wrapText="true" maxWidth="Infinity"/>

    <!-- ══ ALERT (hidden by default) ══ -->
    <HBox fx:id="alertBox" spacing="8" alignment="CENTER_LEFT" visible="false" managed="false"
          style="-fx-background-color: rgba(231,76,60,0.9); -fx-background-radius: 8; -fx-padding: 10;">
        <Label fx:id="alertLabel" text="" style="-fx-text-fill: white; -fx-font-weight: bold;"
               wrapText="true"/>
    </HBox>

    <!-- ══ FOOTER ══ -->
    <Label fx:id="lastUpdateLabel" text="--"
           style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 10;"
           alignment="CENTER_RIGHT" maxWidth="Infinity"/>
</VBox>