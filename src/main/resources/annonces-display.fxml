<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.Blend?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="rootPane" prefHeight="700.0" prefWidth="1100.0" stylesheets="@customTheme.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.annonces.AnnonceDisplayController">

    <left>
        <VBox fx:id="sidebar" prefWidth="68.0" styleClass="sidebar" BorderPane.alignment="CENTER">
            <children>
                <Button fx:id="btnToggle" maxWidth="Infinity" onAction="#handleToggleSidebar" styleClass="nav-button, logo-button">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="20">
                            <ImageView fitHeight="22" fitWidth="22" preserveRatio="true">
                                <image>
                                    <Image url="@icons/logo.png" />
                                </image>
                                <effect>
                                    <Blend />
                                </effect>
                            </ImageView>
                            <Label style="-fx-font-weight: bold;" styleClass="nav-label" text="Momentum" />
                        </HBox>
                    </graphic>
                    <VBox.margin>
                        <Insets bottom="20.0" top="10.0" />
                    </VBox.margin>
                </Button>

                <VBox spacing="10.0">
                    <children>
                        <Button fx:id="btnHome" maxWidth="Infinity" onAction="#showHome" styleClass="nav-button, nav-active">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="20">
                                    <children>
                                        <StackPane maxWidth="25" minWidth="25">
                                            <ImageView fitHeight="22" fitWidth="22" preserveRatio="true">
                                                <image>
                                                    <Image url="@icons/home.png" />
                                                </image>
                                            </ImageView>
                                        </StackPane>
                                        <Label styleClass="nav-label" text="Home" />
                                    </children>
                                </HBox>
                            </graphic>
                        </Button>

                        <Button fx:id="btnFormation" maxWidth="Infinity" onAction="#showFormation" styleClass="nav-button">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="20">
                                    <children>
                                        <StackPane maxWidth="25" minWidth="25">
                                            <ImageView fitHeight="22" fitWidth="22" preserveRatio="true">
                                                <image>
                                                    <Image url="@icons/edit.png" />
                                                </image>
                                            </ImageView>
                                        </StackPane>
                                        <Label styleClass="nav-label" text="Formations" />
                                    </children>
                                </HBox>
                            </graphic>
                        </Button>

                        <Button fx:id="btnDemande" maxWidth="Infinity" onAction="#showDemande" styleClass="nav-button">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="20">
                                    <children>
                                        <StackPane maxWidth="25" minWidth="25">
                                            <ImageView fitHeight="22" fitWidth="22" preserveRatio="true">
                                                <image>
                                                    <Image url="@icons/send.png" />
                                                </image>
                                            </ImageView>
                                        </StackPane>
                                        <Label styleClass="nav-label" text="Demandes" />
                                    </children>
                                </HBox>
                            </graphic>
                        </Button>

                        <Button fx:id="btnEmployer" maxWidth="Infinity" onAction="#showEmployer" styleClass="nav-button">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="20">
                                    <children>
                                        <StackPane maxWidth="25" minWidth="25">
                                            <ImageView fitHeight="22" fitWidth="22" preserveRatio="true">
                                                <image>
                                                    <Image url="@icons/users.png" />
                                                </image>
                                            </ImageView>
                                        </StackPane>
                                        <Label styleClass="nav-label" text="Utilisateurs" />
                                    </children>
                                </HBox>
                            </graphic>
                        </Button>

                        <Button fx:id="btnProjet" maxWidth="Infinity" onAction="#showProjet" styleClass="nav-button">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="20">
                                    <children>
                                        <StackPane maxWidth="25" minWidth="25">
                                            <ImageView fitHeight="22" fitWidth="22" preserveRatio="true">
                                                <image>
                                                    <Image url="@icons/layout.png" />
                                                </image>
                                            </ImageView>
                                        </StackPane>
                                        <Label styleClass="nav-label" text="Projets" />
                                    </children>
                                </HBox>
                            </graphic>
                        </Button>

                        <Button fx:id="btnOffre" maxWidth="Infinity" onAction="#showOffres" styleClass="nav-button">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="20">
                                    <children>
                                        <StackPane maxWidth="25" minWidth="25">
                                            <ImageView fitHeight="22" fitWidth="22" preserveRatio="true">
                                                <image>
                                                    <Image url="@icons/share.png" />
                                                </image>
                                            </ImageView>
                                        </StackPane>
                                        <Label styleClass="nav-label" text="Offres d'emploi" />
                                    </children>
                                </HBox>
                            </graphic>
                        </Button>
                    </children>
                </VBox>
            </children>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="main-scroll-pane">
            <VBox spacing="0" style="-fx-background-color: #f5f7fa;" alignment="TOP_CENTER">

                <VBox style="-fx-background-color: white; -fx-border-color: #dfe3e8; -fx-border-width: 0 0 1 0;"
                      maxWidth="680" prefWidth="680">
                    <padding>
                        <Insets top="24" right="32" bottom="24" left="32"/>
                    </padding>

                    <HBox alignment="CENTER_LEFT" spacing="20">
                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                            <Label text="Fil d'actualité" style="-fx-font-size: 28px; -fx-font-weight: 700; -fx-text-fill: #1a1f36;"/>
                            <Label text="Restez informé des dernières annonces de l'entreprise" style="-fx-font-size: 14px; -fx-text-fill: #697386;"/>
                        </VBox>

                        <ComboBox fx:id="comboFilter" promptText="Tout voir" prefWidth="160"
                                  style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #dfe3e8; -fx-border-radius: 8; -fx-border-width: 1.5; -fx-padding: 10 16; -fx-font-size: 14px; -fx-font-weight: 500;"/>
                    </HBox>
                </VBox>

                <VBox fx:id="postsContainer" spacing="16" style="-fx-padding: 24 0;"
                      maxWidth="680" prefWidth="680"/>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
