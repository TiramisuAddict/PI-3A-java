<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.projets.ProjetsController"
            style="-fx-background-color: #F1F5F9;">

    <children>
        <TabPane tabClosingPolicy="UNAVAILABLE"
                 AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                 AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

            <tabs>

                <!-- TAB 1: Projects list -->
                <Tab text="📁 Projets">
                    <content>
                        <AnchorPane style="-fx-background-color: #F1F5F9;">
                            <children>
                                <SplitPane dividerPositions="0.62"
                                           AnchorPane.topAnchor="0.0" AnchorPane.rightAnchor="0.0"
                                           AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                                           style="-fx-background-color: transparent;">

                                    <!-- LEFT: Dashboard + list -->
                                    <VBox spacing="16" style="-fx-padding:20; -fx-background-color: #F1F5F9;">

                                        <!-- Header -->
                                        <VBox spacing="4">
                                            <Label text="📊 Dashboard des Projets" style="-fx-font-size:24px; -fx-font-weight:800; -fx-text-fill: #1E293B;"/>
                                            <Label text="Visualisez et gérez tous vos projets" style="-fx-text-fill: #64748B;"/>
                                        </VBox>

                                        <!-- Stats cards -->
                                        <HBox spacing="16">
                                            <VBox spacing="4" prefWidth="140"
                                                  style="-fx-padding:16; -fx-background-radius:12; -fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);">
                                                <Label text="📁 Total" style="-fx-text-fill: #64748B; -fx-font-size: 12px;"/>
                                                <Label fx:id="projectsCountLabel" text="0" style="-fx-font-size:28px; -fx-font-weight:800; -fx-text-fill: #1E293B;"/>
                                            </VBox>

                                            <VBox spacing="4" prefWidth="140"
                                                  style="-fx-padding:16; -fx-background-radius:12; -fx-background-color: linear-gradient(to bottom right, #DCFCE7, #BBF7D0);">
                                                <Label text="🚀 Actifs" style="-fx-text-fill: #166534; -fx-font-size: 12px;"/>
                                                <Label fx:id="activeCountLabel" text="0" style="-fx-font-size:28px; -fx-font-weight:800; -fx-text-fill: #166534;"/>
                                            </VBox>

                                            <Region HBox.hgrow="ALWAYS"/>

                                            <Button fx:id="btnNewProject" text="+ Nouveau projet"
                                                    style="-fx-background-color: linear-gradient(to right, #4F46E5, #7C3AED); -fx-text-fill: white; -fx-font-weight: 700; -fx-background-radius: 10; -fx-padding: 12 20; -fx-cursor: hand;"/>
                                        </HBox>

                                        <!-- Search + filters -->
                                        <HBox spacing="10" alignment="CENTER_LEFT"
                                              style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.04), 6, 0, 0, 1);">
                                            <TextField fx:id="searchField" promptText="🔍 Rechercher un projet..." HBox.hgrow="ALWAYS"
                                                       style="-fx-background-color: #F8FAFC; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #E2E8F0;"/>
                                            <ComboBox fx:id="statusFilter" promptText="Statut" prefWidth="130" style="-fx-background-radius: 8;"/>
                                            <ComboBox fx:id="sortBox" promptText="Trier" prefWidth="140" style="-fx-background-radius: 8;"/>
                                            <Button fx:id="btnRefresh" text="🔄" style="-fx-background-color: #F1F5F9; -fx-background-radius: 8; -fx-cursor: hand;"/>
                                        </HBox>

                                        <!-- List -->
                                        <ListView fx:id="projectsList" VBox.vgrow="ALWAYS"
                                                  style="-fx-background-color: transparent; -fx-background: transparent;"/>

                                        <Label fx:id="emptyStateLabel"
                                               text="📭 Aucun projet pour le moment. Créez-en un !"
                                               visible="false" managed="false" style="-fx-text-fill: #94A3B8; -fx-font-size: 14px;"/>
                                    </VBox>

                                    <!-- RIGHT: Details panel -->
                                    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: white; -fx-background: white;">
                                        <content>
                                            <VBox spacing="16" style="-fx-padding:20; -fx-background-color: white;">

                                                <Label text="📋 Détails du Projet" style="-fx-font-size:18px; -fx-font-weight:800; -fx-text-fill: #1E293B;"/>
                                                <Separator style="-fx-background-color: #E2E8F0;"/>

                                                <VBox spacing="6">
                                                    <Label text="Nom du projet" style="-fx-font-weight: 600; -fx-text-fill: #475569;"/>
                                                    <TextField fx:id="detailNomField" promptText="Nom..."
                                                               style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #E2E8F0; -fx-padding: 10;"/>
                                                </VBox>

                                                <VBox spacing="6">
                                                    <Label text="Description" style="-fx-font-weight: 600; -fx-text-fill: #475569;"/>
                                                    <TextArea fx:id="detailDescArea" promptText="Description..." prefRowCount="4" wrapText="true"
                                                              style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #E2E8F0;"/>
                                                </VBox>

                                                <HBox spacing="12">
                                                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                                                        <Label text="📅 Date début" style="-fx-font-weight: 600; -fx-text-fill: #475569;"/>
                                                        <DatePicker fx:id="detailDebutPicker" maxWidth="Infinity"/>
                                                    </VBox>
                                                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                                                        <Label text="📅 Date fin prévue" style="-fx-font-weight: 600; -fx-text-fill: #475569;"/>
                                                        <DatePicker fx:id="detailFinPrevuePicker" maxWidth="Infinity"/>
                                                    </VBox>
                                                </HBox>

                                                <HBox spacing="12">
                                                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                                                        <Label text="📊 Statut" style="-fx-font-weight: 600; -fx-text-fill: #475569;"/>
                                                        <ComboBox fx:id="detailStatutBox" maxWidth="Infinity" promptText="Statut"/>
                                                    </VBox>
                                                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                                                        <Label text="🎯 Priorité" style="-fx-font-weight: 600; -fx-text-fill: #475569;"/>
                                                        <ComboBox fx:id="detailPrioriteBox" maxWidth="Infinity" promptText="Priorité"/>
                                                    </VBox>
                                                </HBox>

                                                <VBox spacing="6">
                                                    <Label text="👤 Responsable" style="-fx-font-weight: 600; -fx-text-fill: #475569;"/>
                                                    <ComboBox fx:id="detailResponsableBox" maxWidth="Infinity" promptText="Responsable"/>
                                                </VBox>

                                                <!-- Team Management Section -->
                                                <Separator style="-fx-background-color: #E2E8F0;"/>
                                                <HBox alignment="CENTER_LEFT" spacing="10">
                                                    <Label text="👥 Équipe du projet" style="-fx-font-size:16px; -fx-font-weight:700; -fx-text-fill: #1E293B;"/>
                                                    <Region HBox.hgrow="ALWAYS"/>
                                                    <Label fx:id="teamCountLabel" text="0 membre(s)" style="-fx-text-fill: #64748B; -fx-font-size: 12px;"/>
                                                </HBox>

                                                <HBox spacing="8">
                                                    <ComboBox fx:id="addEmployeeBox" HBox.hgrow="ALWAYS" maxWidth="Infinity" promptText="Ajouter un employé..."/>
                                                    <Button fx:id="btnAddEmployee" text="+ Ajouter"
                                                            style="-fx-background-color: #DBEAFE; -fx-text-fill: #1D4ED8; -fx-background-radius: 8; -fx-cursor: hand;"/>
                                                </HBox>

                                                <ListView fx:id="detailTeamListView" prefHeight="120"
                                                          style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #E2E8F0;"/>

                                                <HBox spacing="10">
                                                    <Button fx:id="btnSaveDetails" text="💾 Modifier" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                                            style="-fx-background-color: #4F46E5; -fx-text-fill: white; -fx-font-weight: 700; -fx-background-radius: 8; -fx-padding: 12; -fx-cursor: hand;"/>
                                                    <Button fx:id="btnDeleteProject" text="🗑 Supprimer" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                                            style="-fx-background-color: #FEE2E2; -fx-text-fill: #DC2626; -fx-font-weight: 700; -fx-background-radius: 8; -fx-padding: 12; -fx-cursor: hand;"/>
                                                </HBox>

                                                <Label fx:id="detailsInfoLabel" text="" style="-fx-text-fill: #059669; -fx-font-weight: 600;"/>
                                            </VBox>
                                        </content>
                                    </ScrollPane>

                                </SplitPane>
                            </children>
                        </AnchorPane>
                    </content>
                </Tab>

                <!-- TAB 2: Tasks -->
                <Tab text="✅ Tâches">
                    <content>
                        <AnchorPane style="-fx-background-color: #F1F5F9;">
                            <children>
                                <VBox spacing="0" AnchorPane.topAnchor="0.0" AnchorPane.rightAnchor="0.0"
                                      AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0">

                                    <!-- Header -->
                                    <VBox spacing="8" style="-fx-background-color: linear-gradient(to right, #059669, #10B981); -fx-padding: 20;">
                                        <HBox spacing="12" alignment="CENTER_LEFT">
                                            <VBox spacing="2">
                                                <Label text="✅ Gestion des Tâches" style="-fx-font-size:22px; -fx-font-weight:800; -fx-text-fill: white;"/>
                                                <HBox spacing="8" alignment="CENTER_LEFT">
                                                    <Label text="Projet:" style="-fx-text-fill: rgba(255,255,255,0.8);"/>
                                                    <Label fx:id="selectedProjectTitle" text="(Aucun projet sélectionné)"
                                                           style="-fx-text-fill: white; -fx-font-weight: 700;"/>
                                                </HBox>
                                            </VBox>
                                            <Region HBox.hgrow="ALWAYS"/>
                                            <Button fx:id="btnCreateTaskInline" text="+ Nouvelle tâche"
                                                    style="-fx-background-color: white; -fx-text-fill: #059669; -fx-font-weight: 700; -fx-background-radius: 10; -fx-padding: 10 20; -fx-cursor: hand;"/>
                                        </HBox>
                                    </VBox>

                                    <!-- Content -->
                                    <VBox spacing="16" VBox.vgrow="ALWAYS" style="-fx-padding: 20;">

                                        <!-- Stats Row -->
                                        <HBox spacing="16">
                                            <VBox spacing="2" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 6, 0, 0, 1);">
                                                <Label text="Total" style="-fx-text-fill: #64748B; -fx-font-size: 12px;"/>
                                                <Label fx:id="taskTotalLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: 800; -fx-text-fill: #1E293B;"/>
                                            </VBox>
                                            <VBox spacing="2" style="-fx-background-color: #DCFCE7; -fx-background-radius: 12; -fx-padding: 16;">
                                                <Label text="Terminées" style="-fx-text-fill: #166534; -fx-font-size: 12px;"/>
                                                <Label fx:id="taskCompletedLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: 800; -fx-text-fill: #166534;"/>
                                            </VBox>
                                            <VBox spacing="2" style="-fx-background-color: #FEF3C7; -fx-background-radius: 12; -fx-padding: 16;">
                                                <Label text="En cours" style="-fx-text-fill: #92400E; -fx-font-size: 12px;"/>
                                                <Label fx:id="taskInProgressLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: 800; -fx-text-fill: #92400E;"/>
                                            </VBox>
                                            <Region HBox.hgrow="ALWAYS"/>
                                        </HBox>

                                        <!-- Search -->
                                        <HBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.04), 6, 0, 0, 1);">
                                            <TextField fx:id="taskSearchField" promptText="🔍 Rechercher une tâche..." HBox.hgrow="ALWAYS"
                                                       style="-fx-background-color: #F8FAFC; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #E2E8F0;"/>
                                            <ComboBox fx:id="taskStatusFilter" promptText="Statut" prefWidth="140" style="-fx-background-radius: 8;"/>
                                            <Button fx:id="btnRefreshTasks" text="🔄"
                                                    style="-fx-background-color: #F1F5F9; -fx-background-radius: 8; -fx-cursor: hand;"/>
                                        </HBox>

                                        <!-- Tasks Table -->
                                        <TableView fx:id="tasksTable" VBox.vgrow="ALWAYS"
                                                   style="-fx-background-color: white; -fx-background-radius: 12;">
                                            <columns>
                                                <TableColumn fx:id="colTitre" text="📝 TÂCHE" prefWidth="200"/>
                                                <TableColumn fx:id="colAssignee" text="👤 ASSIGNÉ" prefWidth="120"/>
                                                <TableColumn fx:id="colPriorite" text="🎯 PRIORITÉ" prefWidth="100"/>
                                                <TableColumn fx:id="colStatut" text="📊 STATUT" prefWidth="100"/>
                                                <TableColumn fx:id="colDateDebut" text="📅 DÉBUT" prefWidth="100"/>
                                                <TableColumn fx:id="colDueDate" text="📅 LIMITE" prefWidth="100"/>
                                                <TableColumn fx:id="colProgress" text="📈 PROGRESS" prefWidth="100"/>
                                                <TableColumn fx:id="colActions" text="⚙️ ACTIONS" prefWidth="140"/>
                                            </columns>
                                        </TableView>

                                        <Label fx:id="taskInfoLabel" text="" style="-fx-text-fill: #64748B;"/>
                                    </VBox>

                                </VBox>
                            </children>

                        </AnchorPane>
                    </content>
                </Tab>

            </tabs>
        </TabPane>
    </children>
</AnchorPane>
