<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.projets.ProjetsController"
            style="-fx-background-color: #F1F5F9;">

    <children>
        <VBox spacing="0" AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">

            <!-- Top User Bar -->
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-background-color: linear-gradient(to right, #1E293B, #334155); -fx-padding: 10 20;">
                <Label text="🚀 Gestion de Projets" style="-fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 14px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox alignment="CENTER_RIGHT" spacing="12">
                    <!-- Google Calendar Section -->
                    <VBox alignment="CENTER" spacing="2">
                        <Button fx:id="btnGoogleCalendar" text="📅 Connecter Calendar"
                                style="-fx-background-color: #DBEAFE; -fx-text-fill: #1D4ED8; -fx-background-radius: 8; -fx-padding: 6 12; -fx-cursor: hand; -fx-font-size: 11px;"/>
                        <Label fx:id="calendarStatusLabel" text="⚪ Non connecté" style="-fx-text-fill: #94A3B8; -fx-font-size: 9px;"/>
                    </VBox>
                    <Separator orientation="VERTICAL" style="-fx-background-color: rgba(255,255,255,0.2);"/>
                    <VBox alignment="CENTER_RIGHT" spacing="0">
                        <Label fx:id="currentUserLabel" text="👤 Utilisateur" style="-fx-text-fill: white; -fx-font-weight: 600; -fx-font-size: 12px;"/>
                        <Label fx:id="currentRoleLabel" text="Role" style="-fx-text-fill: #94A3B8; -fx-font-size: 10px;"/>
                    </VBox>
                    <Button fx:id="btnLogout" text="🚪 Déconnexion"
                            style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: #F87171; -fx-background-radius: 8; -fx-padding: 6 12; -fx-cursor: hand; -fx-font-size: 11px;"/>
                </HBox>
            </HBox>

            <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">

                <tabs>

                    <!-- TAB 1: Projects list -->
                    <Tab text="📁 Projets">
                        <content>
                            <AnchorPane style="-fx-background-color: #F1F5F9;">
                                <children>
                                    <SplitPane dividerPositions="0.62"
                                               AnchorPane.topAnchor="0.0" AnchorPane.rightAnchor="0.0"
                                               AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                                               style="-fx-background-color: transparent;">

                                        <!-- LEFT: Dashboard + list -->
                                        <VBox spacing="16" style="-fx-padding:20; -fx-background-color: #F1F5F9;">

                                            <!-- Header -->
                                            <HBox alignment="CENTER_LEFT" spacing="12">
                                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                                    <Label text="📊 Dashboard des Projets" style="-fx-font-size:24px; -fx-font-weight:800; -fx-text-fill: #1E293B;"/>
                                                    <Label text="Visualisez et gérez tous vos projets" style="-fx-text-fill: #64748B;"/>
                                                </VBox>
                                            </HBox>

                                            <!-- Stats cards -->
                                            <HBox spacing="16">
                                                <VBox spacing="4" prefWidth="130"
                                                      style="-fx-padding:16; -fx-background-radius:16; -fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 3);">
                                                    <Label text="📁 Total" style="-fx-text-fill: #64748B; -fx-font-size: 11px; -fx-font-weight: 600;"/>
                                                    <Label fx:id="projectsCountLabel" text="0" style="-fx-font-size:32px; -fx-font-weight:800; -fx-text-fill: #1E293B;"/>
                                                    <Label text="projets" style="-fx-text-fill: #94A3B8; -fx-font-size: 10px;"/>
                                                </VBox>

                                                <VBox spacing="4" prefWidth="130"
                                                      style="-fx-padding:16; -fx-background-radius:16; -fx-background-color: linear-gradient(to bottom right, #DCFCE7, #BBF7D0); -fx-effect: dropshadow(gaussian, rgba(22,163,74,0.2), 10, 0, 0, 3);">
                                                    <Label text="🚀 Actifs" style="-fx-text-fill: #166534; -fx-font-size: 11px; -fx-font-weight: 600;"/>
                                                    <Label fx:id="activeCountLabel" text="0" style="-fx-font-size:32px; -fx-font-weight:800; -fx-text-fill: #166534;"/>
                                                    <Label text="en cours" style="-fx-text-fill: #15803D; -fx-font-size: 10px;"/>
                                                </VBox>

                                                <Region HBox.hgrow="ALWAYS"/>

                                                <Button fx:id="btnNewProject" text="+ Nouveau projet"
                                                        style="-fx-background-color: linear-gradient(to right, #4F46E5, #7C3AED); -fx-text-fill: white; -fx-font-weight: 700; -fx-background-radius: 12; -fx-padding: 14 24; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(79,70,229,0.4), 8, 0, 0, 2);"/>
                                            </HBox>

                                            <!-- Search + filters -->
                                            <HBox spacing="10" alignment="CENTER_LEFT"
                                                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);">
                                                <TextField fx:id="searchField" promptText="🔍 Rechercher un projet..." HBox.hgrow="ALWAYS"
                                                           style="-fx-background-color: #F8FAFC; -fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #E2E8F0; -fx-padding: 10;"/>
                                                <ComboBox fx:id="statusFilter" promptText="Statut" prefWidth="130" style="-fx-background-radius: 10;"/>
                                                <ComboBox fx:id="sortBox" promptText="Trier" prefWidth="140" style="-fx-background-radius: 10;"/>
                                                <Button fx:id="btnRefresh" text="🔄" style="-fx-background-color: #F1F5F9; -fx-background-radius: 10; -fx-cursor: hand; -fx-padding: 10;"/>
                                            </HBox>

                                            <!-- List -->
                                            <ListView fx:id="projectsList" VBox.vgrow="ALWAYS"
                                                      style="-fx-background-color: transparent; -fx-background: transparent;"/>

                                            <Label fx:id="emptyStateLabel"
                                                   text="📭 Aucun projet pour le moment. Créez-en un !"
                                                   visible="false" managed="false" style="-fx-text-fill: #94A3B8; -fx-font-size: 14px;"/>
                                        </VBox>

                                        <!-- RIGHT: Details panel -->
                                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: white; -fx-background: white;">
                                            <content>
                                                <VBox spacing="16" style="-fx-padding:20; -fx-background-color: white;">

                                                    <HBox alignment="CENTER_LEFT" spacing="10">
                                                        <Label text="📋 Détails du Projet" style="-fx-font-size:18px; -fx-font-weight:800; -fx-text-fill: #1E293B;"/>
                                                        <Region HBox.hgrow="ALWAYS"/>
                                                        <Label text="ID" style="-fx-background-color: #E0E7FF; -fx-text-fill: #4338CA; -fx-padding: 4 10; -fx-background-radius: 20; -fx-font-size: 10px; -fx-font-weight: 700;"/>
                                                    </HBox>
                                                    <Separator style="-fx-background-color: #E2E8F0;"/>

                                                <VBox spacing="6">
                                                    <Label text="Nom du projet" style="-fx-font-weight: 600; -fx-text-fill: #475569;"/>
                                                    <TextField fx:id="detailNomField" promptText="Nom..."
                                                               style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #E2E8F0; -fx-padding: 10;"/>
                                                </VBox>

                                                <VBox spacing="6">
                                                    <Label text="Description" style="-fx-font-weight: 600; -fx-text-fill: #475569;"/>
                                                    <TextArea fx:id="detailDescArea" promptText="Description..." prefRowCount="4" wrapText="true"
                                                              style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #E2E8F0;"/>
                                                </VBox>

                                                <HBox spacing="12">
                                                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                                                        <Label text="📅 Date début" style="-fx-font-weight: 600; -fx-text-fill: #475569;"/>
                                                        <DatePicker fx:id="detailDebutPicker" maxWidth="Infinity"/>
                                                    </VBox>
                                                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                                                        <Label text="📅 Date fin prévue" style="-fx-font-weight: 600; -fx-text-fill: #475569;"/>
                                                        <DatePicker fx:id="detailFinPrevuePicker" maxWidth="Infinity"/>
                                                    </VBox>
                                                </HBox>

                                                <HBox spacing="12">
                                                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                                                        <Label text="📊 Statut" style="-fx-font-weight: 600; -fx-text-fill: #475569;"/>
                                                        <ComboBox fx:id="detailStatutBox" maxWidth="Infinity" promptText="Statut"/>
                                                    </VBox>
                                                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                                                        <Label text="🎯 Priorité" style="-fx-font-weight: 600; -fx-text-fill: #475569;"/>
                                                        <ComboBox fx:id="detailPrioriteBox" maxWidth="Infinity" promptText="Priorité"/>
                                                    </VBox>
                                                </HBox>

                                                <VBox spacing="6">
                                                    <Label text="👤 Responsable" style="-fx-font-weight: 600; -fx-text-fill: #475569;"/>
                                                    <ComboBox fx:id="detailResponsableBox" maxWidth="Infinity" promptText="Responsable"/>
                                                </VBox>

                                                <!-- Team Management Section -->
                                                <Separator style="-fx-background-color: #E2E8F0;"/>
                                                <HBox alignment="CENTER_LEFT" spacing="10">
                                                    <Label text="👥 Équipe du projet" style="-fx-font-size:16px; -fx-font-weight:700; -fx-text-fill: #1E293B;"/>
                                                    <Region HBox.hgrow="ALWAYS"/>
                                                    <Label fx:id="teamCountLabel" text="0 membre(s)" style="-fx-text-fill: #64748B; -fx-font-size: 12px;"/>
                                                </HBox>

                                                <HBox spacing="8">
                                                    <ComboBox fx:id="addEmployeeBox" HBox.hgrow="ALWAYS" maxWidth="Infinity" promptText="Ajouter un employé..."/>
                                                    <Button fx:id="btnAddEmployee" text="+ Ajouter"
                                                            style="-fx-background-color: #DBEAFE; -fx-text-fill: #1D4ED8; -fx-background-radius: 8; -fx-cursor: hand;"/>
                                                </HBox>

                                                <ListView fx:id="detailTeamListView" prefHeight="120"
                                                          style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #E2E8F0;"/>

                                                <HBox spacing="10">
                                                    <Button fx:id="btnSaveDetails" text="💾 Modifier" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                                            style="-fx-background-color: #4F46E5; -fx-text-fill: white; -fx-font-weight: 700; -fx-background-radius: 8; -fx-padding: 12; -fx-cursor: hand;"/>
                                                    <Button fx:id="btnDeleteProject" text="🗑 Supprimer" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                                            style="-fx-background-color: #FEE2E2; -fx-text-fill: #DC2626; -fx-font-weight: 700; -fx-background-radius: 8; -fx-padding: 12; -fx-cursor: hand;"/>
                                                </HBox>

                                                <Label fx:id="detailsInfoLabel" text="" style="-fx-text-fill: #059669; -fx-font-weight: 600;"/>
                                            </VBox>
                                        </content>
                                    </ScrollPane>

                                </SplitPane>
                            </children>
                        </AnchorPane>
                    </content>
                </Tab>

                <!-- TAB 2: Tasks - Kanban Board (Light Theme) -->
                <Tab text="✅ Tâches">
                    <content>
                        <AnchorPane style="-fx-background-color: #F8FAFC;">
                            <children>
                                <VBox spacing="0" AnchorPane.topAnchor="0.0" AnchorPane.rightAnchor="0.0"
                                      AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0">

                                    <!-- Header - Clean Modern Style -->
                                    <HBox spacing="16" alignment="CENTER_LEFT"
                                          style="-fx-background-color: white; -fx-padding: 16 24; -fx-border-color: #E2E8F0; -fx-border-width: 0 0 1 0;">
                                        <VBox spacing="4">
                                            <HBox spacing="10" alignment="CENTER_LEFT">
                                                <Label text="📋" style="-fx-font-size: 22px;"/>
                                                <Label fx:id="selectedProjectTitle" text="Sélectionnez un projet"
                                                       style="-fx-text-fill: #1E293B; -fx-font-weight: 700; -fx-font-size: 20px; -fx-font-family: 'Segoe UI', sans-serif;"/>
                                            </HBox>
                                            <Label fx:id="kanbanSubtitle" text="Glissez-déposez les tâches pour changer leur statut"
                                                   style="-fx-text-fill: #64748B; -fx-font-size: 12px; -fx-font-family: 'Segoe UI', sans-serif;"/>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        
                                        <!-- Stats Badges -->
                                        <HBox spacing="12" alignment="CENTER">
                                            <HBox spacing="6" alignment="CENTER" style="-fx-background-color: #F1F5F9; -fx-background-radius: 8; -fx-padding: 8 14;">
                                                <Label text="📋" style="-fx-font-size: 13px;"/>
                                                <Label fx:id="taskTotalLabel" text="0" style="-fx-text-fill: #334155; -fx-font-weight: 700; -fx-font-size: 14px; -fx-font-family: 'Segoe UI', sans-serif;"/>
                                                <Label text="total" style="-fx-text-fill: #64748B; -fx-font-size: 12px; -fx-font-family: 'Segoe UI', sans-serif;"/>
                                            </HBox>
                                            <HBox spacing="6" alignment="CENTER" style="-fx-background-color: #ECFDF5; -fx-background-radius: 8; -fx-padding: 8 14;">
                                                <Label text="✅" style="-fx-font-size: 13px;"/>
                                                <Label fx:id="taskCompletedLabel" text="0" style="-fx-text-fill: #059669; -fx-font-weight: 700; -fx-font-size: 14px; -fx-font-family: 'Segoe UI', sans-serif;"/>
                                            </HBox>
                                            <HBox spacing="6" alignment="CENTER" style="-fx-background-color: #EFF6FF; -fx-background-radius: 8; -fx-padding: 8 14;">
                                                <Label text="🔄" style="-fx-font-size: 13px;"/>
                                                <Label fx:id="taskInProgressLabel" text="0" style="-fx-text-fill: #2563EB; -fx-font-weight: 700; -fx-font-size: 14px; -fx-font-family: 'Segoe UI', sans-serif;"/>
                                            </HBox>
                                        </HBox>
                                        
                                        <!-- Search and Actions -->
                                        <HBox spacing="10" alignment="CENTER">
                                            <TextField fx:id="taskSearchField" promptText="🔍 Rechercher..." prefWidth="200"
                                                       style="-fx-background-color: #F1F5F9; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #E2E8F0; -fx-text-fill: #334155; -fx-padding: 10 14; -fx-font-family: 'Segoe UI', sans-serif;"/>
                                            <Button fx:id="btnRefreshTasks" text="↻"
                                                    style="-fx-background-color: #F1F5F9; -fx-text-fill: #64748B; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 10 14; -fx-font-size: 14px;"/>
                                            <Button fx:id="btnCreateTaskInline" text="+ Nouvelle tâche"
                                                    style="-fx-background-color: #6366F1; -fx-text-fill: white; -fx-font-weight: 600; -fx-background-radius: 8; -fx-padding: 10 18; -fx-cursor: hand; -fx-font-family: 'Segoe UI', sans-serif;"/>
                                        </HBox>
                                    </HBox>

                                    <!-- Kanban Board Container -->
                                    <HBox fx:id="kanbanBoard" spacing="16" VBox.vgrow="ALWAYS"
                                          style="-fx-padding: 20; -fx-background-color: #F8FAFC;">

                                        <!-- Column: À Faire (To Do) -->
                                        <VBox fx:id="columnTodo" spacing="0" prefWidth="300" minWidth="280"
                                              style="-fx-background-color: #F1F5F9; -fx-background-radius: 12;" VBox.vgrow="ALWAYS">
                                            <HBox alignment="CENTER_LEFT" spacing="8"
                                                  style="-fx-background-color: #F1F5F9; -fx-background-radius: 12 12 0 0; -fx-padding: 14 16;">
                                                <VBox prefWidth="8" prefHeight="8" style="-fx-background-color: #64748B; -fx-background-radius: 4;"/>
                                                <Label text="À Faire" style="-fx-text-fill: #334155; -fx-font-weight: 700; -fx-font-size: 14px; -fx-font-family: 'Segoe UI', sans-serif;"/>
                                                <Region HBox.hgrow="ALWAYS"/>
                                                <Label fx:id="todoCount" text="0"
                                                       style="-fx-background-color: #E2E8F0; -fx-text-fill: #64748B; -fx-padding: 2 10; -fx-background-radius: 10; -fx-font-size: 12px; -fx-font-weight: 600; -fx-font-family: 'Segoe UI', sans-serif;"/>
                                            </HBox>
                                            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                                        VBox.vgrow="ALWAYS" style="-fx-background: #F1F5F9; -fx-background-color: transparent;">
                                                <content>
                                                    <VBox fx:id="todoTasksContainer" spacing="8" style="-fx-padding: 8 12 12 12;"/>
                                                </content>
                                            </ScrollPane>
                                            <HBox fx:id="todoAddCard" alignment="CENTER" spacing="6"
                                                  style="-fx-background-color: transparent; -fx-padding: 12; -fx-cursor: hand;">
                                                <Label text="+ Ajouter une tâche" style="-fx-text-fill: #94A3B8; -fx-font-size: 13px; -fx-font-family: 'Segoe UI', sans-serif;"/>
                                            </HBox>
                                        </VBox>

                                        <!-- Column: En Cours (In Progress) -->
                                        <VBox fx:id="columnInProgress" spacing="0" prefWidth="300" minWidth="280"
                                              style="-fx-background-color: #EFF6FF; -fx-background-radius: 12;" VBox.vgrow="ALWAYS">
                                            <HBox alignment="CENTER_LEFT" spacing="8"
                                                  style="-fx-background-color: #EFF6FF; -fx-background-radius: 12 12 0 0; -fx-padding: 14 16;">
                                                <VBox prefWidth="8" prefHeight="8" style="-fx-background-color: #3B82F6; -fx-background-radius: 4;"/>
                                                <Label text="En Cours" style="-fx-text-fill: #1E40AF; -fx-font-weight: 700; -fx-font-size: 14px; -fx-font-family: 'Segoe UI', sans-serif;"/>
                                                <Region HBox.hgrow="ALWAYS"/>
                                                <Label fx:id="inProgressCount" text="0"
                                                       style="-fx-background-color: #BFDBFE; -fx-text-fill: #1D4ED8; -fx-padding: 2 10; -fx-background-radius: 10; -fx-font-size: 12px; -fx-font-weight: 600; -fx-font-family: 'Segoe UI', sans-serif;"/>
                                            </HBox>
                                            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                                        VBox.vgrow="ALWAYS" style="-fx-background: #EFF6FF; -fx-background-color: transparent;">
                                                <content>
                                                    <VBox fx:id="inProgressTasksContainer" spacing="8" style="-fx-padding: 8 12 12 12;"/>
                                                </content>
                                            </ScrollPane>
                                            <HBox fx:id="inProgressAddCard" alignment="CENTER" spacing="6"
                                                  style="-fx-background-color: transparent; -fx-padding: 12; -fx-cursor: hand;">
                                                <Label text="+ Ajouter une tâche" style="-fx-text-fill: #93C5FD; -fx-font-size: 13px; -fx-font-family: 'Segoe UI', sans-serif;"/>
                                            </HBox>
                                        </VBox>

                                        <!-- Column: Bloquée (Blocked) -->
                                        <VBox fx:id="columnBlocked" spacing="0" prefWidth="300" minWidth="280"
                                              style="-fx-background-color: #FEF2F2; -fx-background-radius: 12;" VBox.vgrow="ALWAYS">
                                            <HBox alignment="CENTER_LEFT" spacing="8"
                                                  style="-fx-background-color: #FEF2F2; -fx-background-radius: 12 12 0 0; -fx-padding: 14 16;">
                                                <VBox prefWidth="8" prefHeight="8" style="-fx-background-color: #EF4444; -fx-background-radius: 4;"/>
                                                <Label text="Bloquée" style="-fx-text-fill: #991B1B; -fx-font-weight: 700; -fx-font-size: 14px; -fx-font-family: 'Segoe UI', sans-serif;"/>
                                                <Region HBox.hgrow="ALWAYS"/>
                                                <Label fx:id="blockedCount" text="0"
                                                       style="-fx-background-color: #FECACA; -fx-text-fill: #DC2626; -fx-padding: 2 10; -fx-background-radius: 10; -fx-font-size: 12px; -fx-font-weight: 600; -fx-font-family: 'Segoe UI', sans-serif;"/>
                                            </HBox>
                                            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                                        VBox.vgrow="ALWAYS" style="-fx-background: #FEF2F2; -fx-background-color: transparent;">
                                                <content>
                                                    <VBox fx:id="blockedTasksContainer" spacing="8" style="-fx-padding: 8 12 12 12;"/>
                                                </content>
                                            </ScrollPane>
                                            <HBox fx:id="blockedAddCard" alignment="CENTER" spacing="6"
                                                  style="-fx-background-color: transparent; -fx-padding: 12; -fx-cursor: hand;">
                                                <Label text="+ Ajouter une tâche" style="-fx-text-fill: #FCA5A5; -fx-font-size: 13px; -fx-font-family: 'Segoe UI', sans-serif;"/>
                                            </HBox>
                                        </VBox>

                                        <!-- Column: Terminée (Done) -->
                                        <VBox fx:id="columnDone" spacing="0" prefWidth="300" minWidth="280"
                                              style="-fx-background-color: #ECFDF5; -fx-background-radius: 12;" VBox.vgrow="ALWAYS">
                                            <HBox alignment="CENTER_LEFT" spacing="8"
                                                  style="-fx-background-color: #ECFDF5; -fx-background-radius: 12 12 0 0; -fx-padding: 14 16;">
                                                <VBox prefWidth="8" prefHeight="8" style="-fx-background-color: #10B981; -fx-background-radius: 4;"/>
                                                <Label text="Terminée" style="-fx-text-fill: #065F46; -fx-font-weight: 700; -fx-font-size: 14px; -fx-font-family: 'Segoe UI', sans-serif;"/>
                                                <Region HBox.hgrow="ALWAYS"/>
                                                <Label fx:id="doneCount" text="0"
                                                       style="-fx-background-color: #A7F3D0; -fx-text-fill: #059669; -fx-padding: 2 10; -fx-background-radius: 10; -fx-font-size: 12px; -fx-font-weight: 600; -fx-font-family: 'Segoe UI', sans-serif;"/>
                                            </HBox>
                                            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                                        VBox.vgrow="ALWAYS" style="-fx-background: #ECFDF5; -fx-background-color: transparent;">
                                                <content>
                                                    <VBox fx:id="doneTasksContainer" spacing="8" style="-fx-padding: 8 12 12 12;"/>
                                                </content>
                                            </ScrollPane>
                                        </VBox>

                                    </HBox>

                                    <!-- Footer Info Bar -->
                                    <HBox alignment="CENTER_LEFT" spacing="10" 
                                          style="-fx-background-color: white; -fx-padding: 10 24; -fx-border-color: #E2E8F0; -fx-border-width: 1 0 0 0;">
                                        <Label fx:id="taskInfoLabel" text="Sélectionnez un projet pour voir les tâches"
                                               style="-fx-text-fill: #64748B; -fx-font-size: 12px; -fx-font-family: 'Segoe UI', sans-serif;"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label text="💡 Glissez les cartes entre colonnes"
                                               style="-fx-text-fill: #94A3B8; -fx-font-size: 11px; -fx-font-family: 'Segoe UI', sans-serif;"/>
                                    </HBox>

                                </VBox>
                            </children>
                        </AnchorPane>
                    </content>
                </Tab>

            </tabs>
        </TabPane>
        </VBox>
    </children>
</AnchorPane>
