<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.HTMLEditor?>

<VBox spacing="15.0" style="-fx-background-color: -color-bg-default;" stylesheets="@../css/customTheme.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.offres.DescriptionOffreController">
    <children>
        <Label style="-fx-font-weight: bold; -fx-font-size: 18;" text="Description de l'offre" />

        <HTMLEditor fx:id="htmlEditor" prefHeight="450.0" prefWidth="750.0" VBox.vgrow="ALWAYS" maxHeight="Infinity" />

        <Button maxWidth="Infinity" onAction="#handleSave" prefHeight="40.0" styleClass="accent" text="Enregistrer et Fermer" />
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>