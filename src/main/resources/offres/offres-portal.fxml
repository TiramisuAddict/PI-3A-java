<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;"
            stylesheets="@../customTheme.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.offres.OffrePortalController">
    <VBox alignment="CENTER" spacing="0.0"
          style="-fx-background-color: -color-bg-subtle;">

        <!-- ENHANCED HERO BLOCK -->
        <StackPane prefHeight="280.0" styleClass="hero-block">
            <VBox.margin>
                <Insets left="0" right="0" top="0"/>
            </VBox.margin>

            <VBox alignment="CENTER" spacing="12.0">
                <padding>
                    <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
                </padding>

                <Label text="Propulsez votre carrière avec Momentum"
                       style="-fx-font-size: 38px; -fx-font-weight: 900; -fx-text-fill: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 8, 0, 0, 2);"
                       textAlignment="CENTER"
                       wrapText="true"/>

                <Label text="Découvrez des milliers d'offres d'emploi adaptées à votre profil."
                       style="-fx-font-size: 16px; -fx-text-fill: rgba(255,255,255,0.95); -fx-font-weight: normal;"
                       textAlignment="CENTER"
                       wrapText="true">
                    <padding>
                        <Insets top="5.0"/>
                    </padding>
                </Label>
            </VBox>
        </StackPane>

        <!-- ENHANCED SEARCH & FILTER BAR -->
        <HBox alignment="CENTER" maxWidth="1050.0" spacing="15.0"
              style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.15), 20, 0, 0, 8); -fx-border-color: -color-border-muted; -fx-border-width: 1; -fx-border-radius: 12;">
            <children>
                <TextField fx:id="txtSearch"
                           prefHeight="45.0"
                           promptText="Rechercher une offre... (ex: UX/UI)"
                           style="-fx-background-color: -color-bg-default; -fx-background-radius: 8; -fx-border-color: -color-border-default; -fx-border-radius: 8; -fx-border-width: 1; -fx-padding: 10 15; -fx-font-size: 14px;"
                           HBox.hgrow="ALWAYS" />

                <ComboBox fx:id="comboFilterCategorie"
                          onAction="#filterOffers"
                          prefHeight="45.0"
                          prefWidth="200.0"
                          promptText="Catégorie"
                          style="-fx-background-color: -color-bg-default; -fx-background-radius: 8; -fx-border-color: -color-border-default; -fx-border-radius: 8; -fx-border-width: 1; -fx-font-size: 13px;"/>

                <ComboBox fx:id="comboFilterTypeContrat"
                          onAction="#filterOffers"
                          prefHeight="45.0"
                          prefWidth="200.0"
                          promptText="Type de contrat"
                          style="-fx-background-color: -color-bg-default; -fx-background-radius: 8; -fx-border-color: -color-border-default; -fx-border-radius: 8; -fx-border-width: 1; -fx-font-size: 13px;"/>
            </children>
            <VBox.margin>
                <Insets top="-35.0" left="20.0" right="20.0"/>
            </VBox.margin>
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
        </HBox>

        <!-- RESULTS SUMMARY -->
        <VBox maxWidth="1050.0" alignment="CENTER_LEFT" spacing="8.0">
            <padding>
                <Insets top="45.0" bottom="15.0" left="20.0" right="20.0"/>
            </padding>
            <children>
                <Label fx:id="lblCount"
                       style="-fx-font-weight: bold; -fx-font-size: 22; -fx-text-fill: -color-fg-default;"
                       text="4 Offres trouvées" />
            </children>
        </VBox>

        <!-- CARDS GRID -->
        <FlowPane fx:id="offersGrid"
                  alignment="TOP_LEFT"
                  hgap="20.0"
                  vgap="20.0"
                  maxWidth="1050.0"
                  prefWidth="1050.0">
            <padding>
                <Insets bottom="50.0" left="20.0" right="20.0" top="5.0" />
            </padding>
        </FlowPane>

    </VBox>
</ScrollPane>