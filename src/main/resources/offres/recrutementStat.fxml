<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" stylesheets="@../css/customTheme.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.offres.RecrutementStatController">
    <content>
        <VBox spacing="30.0" style="-fx-background-color: -color-bg-subtle;">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
            <children>

                <!-- CHART 1: Nombre de candidatures par offre -->
                <VBox styleClass="chart-container">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 16;" text="Nombre de candidatures par offre" />
                        <BarChart fx:id="chartCandidatParOffre" prefHeight="350.0">
                            <xAxis>
                                <CategoryAxis label="Postes" side="BOTTOM" />
                            </xAxis>
                            <yAxis>
                                <NumberAxis label="Candidats" side="LEFT" />
                            </yAxis>
                        </BarChart>
                    </children>
                </VBox>

                <!-- ROW WITH PIE CHART AND SECOND BAR CHART -->
                <HBox spacing="20.0">
                    <children>
                        <!-- CHART 2: Répartition par état -->
                        <VBox prefWidth="400.0" styleClass="chart-container" HBox.hgrow="SOMETIMES">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-font-size: 16;" text="Répartition par État" />
                                <PieChart fx:id="chartEtatCandidatures" prefHeight="350.0" />
                            </children>
                        </VBox>

                        <!-- CHART 3: Score moyen par offre -->
                        <VBox styleClass="chart-container" HBox.hgrow="ALWAYS">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-font-size: 16;" text="Score moyen IA par offre" />
                                <BarChart fx:id="chartScoreMoyenOffre" prefHeight="350.0">
                                    <xAxis>
                                        <CategoryAxis label="Postes" side="BOTTOM" />
                                    </xAxis>
                                    <yAxis>
                                        <NumberAxis label="Score %" side="LEFT" />
                                    </yAxis>
                                </BarChart>
                            </children>
                        </VBox>
                    </children>
                </HBox>

            </children>
        </VBox>
    </content>
</ScrollPane>