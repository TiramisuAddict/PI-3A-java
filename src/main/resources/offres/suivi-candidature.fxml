<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<ScrollPane fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            style="-fx-background-color: transparent; -fx-background: transparent;"
            stylesheets="@../customTheme.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.offres.SuiviCandidatureController">

    <VBox alignment="CENTER" spacing="0.0"
          style="-fx-background-color: -color-bg-subtle;">

        <!-- ENHANCED HERO BLOCK -->
        <StackPane prefHeight="280.0" styleClass="hero-block">
            <VBox.margin>
                <Insets left="0" right="0" top="0"/>
            </VBox.margin>

            <VBox alignment="CENTER" spacing="12.0">
                <padding>
                    <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
                </padding>

                <Label text="Suivre ma Candidature"
                       style="-fx-font-size: 38px; -fx-font-weight: 900; -fx-text-fill: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 8, 0, 0, 2);"
                       textAlignment="CENTER"
                       wrapText="true"/>

                <Label text="Entrez votre code de suivi pour voir l'avancement de votre dossier en temps réel."
                       style="-fx-font-size: 16px; -fx-text-fill: rgba(255,255,255,0.95); -fx-font-weight: normal;"
                       textAlignment="CENTER"
                       wrapText="true">
                    <padding>
                        <Insets top="5.0"/>
                    </padding>
                </Label>
            </VBox>
        </StackPane>

        <!-- ORIGINAL CONTENT WITH PROPER SPACING -->
        <VBox alignment="TOP_CENTER" spacing="30.0">
            <padding>
                <Insets top="50.0" bottom="40.0" left="20.0" right="20.0" />
            </padding>

            <!-- SEARCH HEADER -->
            <HBox alignment="CENTER" maxWidth="1050.0" spacing="15.0"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.15), 20, 0, 0, 8); -fx-border-color: -color-border-muted; -fx-border-width: 1; -fx-border-radius: 12;">
                <children>
                    <TextField fx:id="txtTrackingCode"
                               prefHeight="45.0"
                               promptText="Entrez votre code de suivi (ex: MEDKGF8W)"
                               style="-fx-background-color: -color-bg-default; -fx-background-radius: 8; -fx-border-color: -color-border-default; -fx-border-radius: 8; -fx-border-width: 1; -fx-padding: 10 15; -fx-font-size: 14px;"
                               HBox.hgrow="ALWAYS" />

                    <Button onAction="#handleSearch"
                            prefHeight="45.0"
                            prefWidth="140.0"
                            styleClass="accent"
                            text="Vérifier"
                            style="-fx-background-radius: 8; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                </children>
                <VBox.margin>
                    <Insets top="-85.0" left="20.0" right="20.0"/>
                </VBox.margin>
                <padding>
                    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                </padding>
            </HBox>

            <VBox fx:id="resultContainer" visible="false" alignment="TOP_CENTER" maxWidth="900.0" spacing="20.0" style="-fx-background-color: -color-bg-default; -fx-background-radius: 20; -fx-padding: 40; -fx-border-color: -color-border-muted; -fx-border-radius: 20;">
                <!-- JOB INFO -->
                <VBox alignment="CENTER" spacing="5.0">
                    <Label fx:id="lblPoste" style="-fx-font-weight: bold; -fx-font-size: 20;" text="" />
                </VBox>
                <Separator />
                <!-- UPDATED VISUAL PIPELINE -->
                <HBox alignment="CENTER" spacing="0.0">
                    <!-- Step 1 -->
                    <VBox alignment="CENTER" spacing="8.0">
                        <Circle fx:id="step1Circle" radius="12.0" style="-fx-fill: -color-success-emphasis;" />
                        <Label style="-fx-font-size: 11; -fx-font-weight: bold;" text="Soumis" />
                    </VBox>

                    <Region fx:id="line1"
                            maxHeight="2.0"
                            minHeight="2.0"
                            prefHeight="2.0"
                            prefWidth="100.0"
                            style="-fx-background-color: -color-base-3;"
                            translateY="-10.0" />
                    <!-- Step 2 -->
                    <VBox alignment="CENTER" spacing="8.0">
                        <Circle fx:id="step2Circle" radius="12.0" style="-fx-fill: -color-base-3;" />
                        <Label style="-fx-font-size: 11;" text="Présélection" />
                    </VBox>
                    <!-- Line 2 -->
                    <Region fx:id="line2"
                            maxHeight="2.0"
                            minHeight="2.0"
                            prefHeight="2.0"
                            prefWidth="100.0"
                            style="-fx-background-color: -color-base-3;"
                            translateY="-10.0" />
                    <!-- Step 3 -->
                    <VBox alignment="CENTER" spacing="8.0">
                        <Circle fx:id="step3Circle" radius="12.0" style="-fx-fill: -color-base-3;" />
                        <Label style="-fx-font-size: 11;" text="Entretien" />
                    </VBox>
                    <!-- Line 3 -->
                    <Region fx:id="line3"
                            maxHeight="2.0"
                            minHeight="2.0"
                            prefHeight="2.0"
                            prefWidth="100.0"
                            style="-fx-background-color: -color-base-3;"
                            translateY="-10.0" />
                    <!-- Step 4 -->
                    <VBox alignment="CENTER" spacing="8.0">
                        <Circle fx:id="step4Circle" radius="12.0" style="-fx-fill: -color-base-3;" />
                        <Label style="-fx-font-size: 11;" text="Décision" />
                    </VBox>
                </HBox>
                <!-- STATUS DETAIL MESSAGE -->
                <VBox alignment="CENTER" fx:id="statusMessageBox" spacing="10.0" style="-fx-background-color: -color-accent-subtle; -fx-padding: 20; -fx-background-radius: 10;">
                    <Label fx:id="lblStatusTitle" style="-fx-font-weight: bold; -fx-text-fill: -color-accent-fg;" text="Votre candidature est en cours de révision" />
                    <Label fx:id="lblStatusDesc" alignment="CENTER" text="Notre équipe analyse votre profil par rapport aux exigences du poste. Vous recevrez une notification par email dès que nous passerons à l'étape suivante." textAlignment="CENTER" wrapText="true" />
                </VBox>
            </VBox>
        </VBox>

    </VBox>
</ScrollPane>
