<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<VBox alignment="TOP_CENTER" spacing="30.0" style="-fx-background-color: -color-bg-subtle;" stylesheets="@../customTheme.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.offres.SuiviCandidatureController">
    <padding>
        <Insets top="40.0" bottom="40.0" left="40.0" right="40.0" />
    </padding>
    <!-- SEARCH HEADER -->
    <VBox alignment="CENTER" spacing="10.0">
        <Label style="-fx-font-weight: bold; -fx-font-size: 26;" text="Suivre ma candidature" />
        <Label styleClass="text-muted" text="Entrez votre code de suivi pour voir l'avancement de votre dossier." />
        <HBox alignment="CENTER" spacing="10.0">
            <padding>
                <Insets top="20.0" />
            </padding>
            <TextField fx:id="txtTrackingCode" prefHeight="45.0" prefWidth="350.0" promptText="Ex: MEDKGF8W" />
            <Button onAction="#handleSearch" prefHeight="45.0" prefWidth="120.0" styleClass="accent" text="Vérifier" />
        </HBox>
    </VBox>
    <VBox fx:id="resultContainer" visible="false" alignment="TOP_CENTER" maxWidth="900.0" spacing="20.0" style="-fx-background-color: -color-bg-default; -fx-background-radius: 20; -fx-padding: 40; -fx-border-color: -color-border-muted; -fx-border-radius: 20;">
        <!-- JOB INFO -->
        <VBox alignment="CENTER" spacing="5.0">
            <Label fx:id="lblPoste" style="-fx-font-weight: bold; -fx-font-size: 20;" text="Développeur Fullstack Java" />
            <Label fx:id="lblEntreprise" styleClass="text-muted" text="TechNova Solutions • Sfax, Tunisie" />
        </VBox>
        <Separator />
        <!-- UPDATED VISUAL PIPELINE -->
        <HBox alignment="CENTER" spacing="0.0">
            <!-- Step 1 -->
            <VBox alignment="CENTER" spacing="8.0">
                <Circle fx:id="step1Circle" radius="12.0" style="-fx-fill: -color-success-emphasis;" />
                <Label style="-fx-font-size: 11; -fx-font-weight: bold;" text="Soumis" />
            </VBox>

            <Region fx:id="line1"
                    maxHeight="2.0"
                    minHeight="2.0"
                    prefHeight="2.0"
                    prefWidth="100.0"
                    style="-fx-background-color: -color-base-3;"
                    translateY="-10.0" />
            <!-- Step 2 -->
            <VBox alignment="CENTER" spacing="8.0">
                <Circle fx:id="step2Circle" radius="12.0" style="-fx-fill: -color-base-3;" />
                <Label style="-fx-font-size: 11;" text="Présélection" />
            </VBox>
            <!-- Line 2 -->
            <Region fx:id="line2"
                    maxHeight="2.0"
                    minHeight="2.0"
                    prefHeight="2.0"
                    prefWidth="100.0"
                    style="-fx-background-color: -color-base-3;"
                    translateY="-10.0" />
            <!-- Step 3 -->
            <VBox alignment="CENTER" spacing="8.0">
                <Circle fx:id="step3Circle" radius="12.0" style="-fx-fill: -color-base-3;" />
                <Label style="-fx-font-size: 11;" text="Entretien" />
            </VBox>
            <!-- Line 3 -->
            <Region fx:id="line3"
                    maxHeight="2.0"
                    minHeight="2.0"
                    prefHeight="2.0"
                    prefWidth="100.0"
                    style="-fx-background-color: -color-base-3;"
                    translateY="-10.0" />
            <!-- Step 4 -->
            <VBox alignment="CENTER" spacing="8.0">
                <Circle fx:id="step4Circle" radius="12.0" style="-fx-fill: -color-base-3;" />
                <Label style="-fx-font-size: 11;" text="Décision" />
            </VBox>
        </HBox>
        <!-- STATUS DETAIL MESSAGE -->
        <VBox alignment="CENTER" fx:id="statusMessageBox" spacing="10.0" style="-fx-background-color: -color-accent-subtle; -fx-padding: 20; -fx-background-radius: 10;">
            <Label fx:id="lblStatusTitle" style="-fx-font-weight: bold; -fx-text-fill: -color-accent-fg;" text="Votre candidature est en cours de révision" />
            <Label fx:id="lblStatusDesc" alignment="CENTER" text="Notre équipe analyse votre profil par rapport aux exigences du poste. Vous recevrez une notification par email dès que nous passerons à l'étape suivante." textAlignment="CENTER" wrapText="true" />
        </VBox>
    </VBox>
</VBox>