<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.offres.CandidatController">
    <!-- LEFT: LIST AND FILTERS -->
    <VBox spacing="20.0" HBox.hgrow="ALWAYS">
        <padding>
            <Insets bottom="25.0" left="25.0" right="25.0" top="25.0"/>
        </padding>
        <!-- TOP: OFFER SELECTION -->
        <VBox spacing="10.0"
              style="-fx-background-color: -color-bg-subtle; -fx-padding: 15; -fx-background-radius: 12;">
            <Label style="-fx-font-weight: bold;" text="Sélectionner une offre pour voir les candidats"/>
            <HBox alignment="CENTER_LEFT" spacing="15.0">
                <ComboBox fx:id="comboFilterOffre" onAction="#loadCandidatData" prefHeight="35.0"
                          prefWidth="350.0" promptText="Choisir une offre..." styleClass="rounded"/>
                <Region HBox.hgrow="ALWAYS"/>
<!--                <TextField fx:id="txtSearchCandidat" prefHeight="35.0" prefWidth="200.0"-->
<!--                           promptText="Rechercher..."/>-->
            </HBox>
        </VBox>
        <FlowPane fx:id="StatisticsPane" prefHeight="100.0" prefWidth="608.0">
            <VBox prefWidth="180.0"
                  style="-fx-background-color: -color-bg-subtle; -fx-background-radius: 5; -fx-padding: 15; -fx-border-color: -color-border-muted; -fx-border-radius: 5;">
                <Label text="En attente" textFill="#868686"/>
                <Label fx:id="lblEnAttente" style="-fx-font-size: 18; -fx-font-weight: bold;" text="0"/>
                <opaqueInsets>
                    <Insets/>
                </opaqueInsets>
                <FlowPane.margin>
                    <Insets left="10.0" right="10.0" top="20.0"/>
                </FlowPane.margin>
            </VBox>
            <VBox layoutX="221.0" layoutY="10.0" prefWidth="180.0"
                  style="-fx-background-color: -color-bg-subtle; -fx-background-radius: 5; -fx-padding: 15; -fx-border-color: -color-border-muted; -fx-border-radius: 5;">
                <Label text="Présélection" textFill="#868686"/>
                <Label fx:id="lblPreselectionne" style="-fx-font-size: 22; -fx-font-weight: bold;" text="0"/>
                <opaqueInsets>
                    <Insets/>
                </opaqueInsets>
                <FlowPane.margin>
                    <Insets left="10.0" right="10.0" top="20.0"/>
                </FlowPane.margin>
            </VBox>
            <VBox layoutX="422.0" layoutY="10.0" prefWidth="180.0"
                  style="-fx-background-color: -color-bg-subtle; -fx-background-radius: 5; -fx-padding: 15; -fx-border-color: -color-border-muted; -fx-border-radius: 5;">
                <Label text="Entretien" textFill="#868686"/>
                <Label fx:id="lblEntretien" style="-fx-font-size: 22; -fx-font-weight: bold;" text="0"/>
                <opaqueInsets>
                    <Insets/>
                </opaqueInsets>
                <FlowPane.margin>
                    <Insets left="10.0" right="10.0" top="20.0"/>
                </FlowPane.margin>
            </VBox>
            <VBox layoutX="422.0" layoutY="10.0" prefWidth="180.0"
                  style="-fx-background-color: -color-bg-subtle; -fx-background-radius: 5; -fx-padding: 15; -fx-border-color: -color-border-muted; -fx-border-radius: 5;">
                <Label text="Accepté" textFill="#868686"/>
                <Label fx:id="lblAccepte" style="-fx-font-size: 22; -fx-font-weight: bold;" text="0"/>
                <opaqueInsets>
                    <Insets/>
                </opaqueInsets>
                <FlowPane.margin>
                    <Insets left="10.0" right="10.0" top="20.0"/>
                </FlowPane.margin>
            </VBox>
            <VBox.margin>
                <Insets/>
            </VBox.margin>
            <padding>
                <Insets top="-15.0"/>
            </padding>
        </FlowPane>
        <TableView fx:id="tableCandidats" styleClass="striped, borderless" VBox.vgrow="ALWAYS">
            <columns>
                <!-- Combiner Prénom + Nom -->
                <TableColumn fx:id="colIdentite" prefWidth="200.0" text="Candidat"/>
                <TableColumn fx:id="colEmail" prefWidth="180.0" text="Email"/>
                <TableColumn fx:id="colEtat" prefWidth="150.0" text="Phase Actuelle"/>
                <TableColumn fx:id="colDate" prefWidth="150.0" text="Date de Candidature"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </VBox>
    <!-- This is the VBox on the right side of the HBox (side-inspector) -->
    <VBox spacing="20.0" styleClass="side-inspector">
        <padding>
            <Insets bottom="25.0" left="25.0" right="25.0" top="25.0"/>
        </padding>
        <Label style="-fx-font-weight: bold; -fx-font-size: 18px;" text="Détails du Candidat"/>
        <Separator/>
        <VBox spacing="5.0">
            <Label fx:id="lblFullname" style="-fx-font-weight: bold; -fx-font-size: 16px;"
                   text="Nom du Candidat"/>
            <Label fx:id="lblEmail" styleClass="text-muted" text="Email"/>
            <Label fx:id="lblPhone" styleClass="text-muted" text="Téléphone"/>
        </VBox>
        <!-- Document Section -->
        <VBox spacing="10.0">
            <Label style="-fx-font-weight: bold;" text="Documents"/>
            <Button fx:id="btnDownloadCV" maxWidth="Infinity" onAction="#handleDownloadCV"
                    styleClass="button-outlined" text="📄 Télécharger CV"/>
            <Button fx:id="btnDownloadLettre" maxWidth="Infinity" onAction="#handleDownloadLettre"
                    styleClass="button-outlined" text="✉ Lettre de Motivation"/>
        </VBox>
        <VBox spacing="5.0" VBox.vgrow="ALWAYS">
            <Label layoutX="10.0" layoutY="40.0" style="-fx-font-weight: bold;" text="Phase"/>
            <ComboBox fx:id="comboUpdatePhase" prefWidth="150.0"/>
            <Label style="-fx-font-weight: bold;" text="Notes"/>
            <TextArea fx:id="txtNotes" prefHeight="200" promptText="Notes..." wrapText="true"
                      VBox.vgrow="ALWAYS"/>
        </VBox>
        <Button defaultButton="true" maxWidth="Infinity" mnemonicParsing="false" text="Save"
                onAction="#updateCandidatStatus"/>
    </VBox>
</HBox>
