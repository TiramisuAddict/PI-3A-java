<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="900.0"
            stylesheets="@/css/customTheme.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.employers.RHetAdminE.ModifierDemandeController">
    <children>
        <ScrollPane fitToWidth="true" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <content>
                <VBox spacing="15.0" style="-fx-background-color: #f5f6fa;">
                    <padding>
                        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
                    </padding>
                    <children>
                        <!-- Header -->
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                            <children>
                                <Button onAction="#retourListe" text="← Retour"
                                        style="-fx-background-color: #95a5a6; -fx-text-fill: white;
                                               -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 8 15;">
                                    <font><Font name="System Bold" size="12.0" /></font>
                                </Button>
                                <Label fx:id="headerLabel" text="✏️ Modifier Demande" style="-fx-text-fill: #2c3e50;">
                                    <font><Font name="System Bold" size="26.0" /></font>
                                </Label>
                            </children>
                        </HBox>

                        <!-- Main Form Card -->
                        <VBox spacing="20" style="-fx-background-color: white; -fx-background-radius: 12;
                                                   -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 3);">
                            <children>
                                <Label text="📋 Informations Générales" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #4A5DEF;" />
                                <Separator />

                                <GridPane hgap="20.0" vgap="15.0">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="100.0" maxWidth="120.0" />
                                        <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" />
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="100.0" maxWidth="120.0" />
                                        <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" />
                                    </columnConstraints>
                                    <children>
                                        <!-- Row 0: Titre & Catégorie -->
                                        <Label text="Titre *" style="-fx-font-weight: bold; -fx-text-fill: #555;" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                        <VBox spacing="3" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                            <TextField fx:id="titreField" promptText="Titre de la demande"
                                                       style="-fx-background-radius: 8; -fx-padding: 10;" />
                                            <Label fx:id="titreError" text="" style="-fx-text-fill: #e74c3c; -fx-font-size: 11;" />
                                        </VBox>

                                        <Label text="Catégorie *" style="-fx-font-weight: bold; -fx-text-fill: #555;" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                                        <VBox spacing="3" GridPane.columnIndex="3" GridPane.rowIndex="0">
                                            <ComboBox fx:id="categorieCombo" maxWidth="1.7976931348623157E308"
                                                      promptText="Sélectionnez" style="-fx-background-radius: 8;" />
                                            <Label fx:id="categorieError" text="" style="-fx-text-fill: #e74c3c; -fx-font-size: 11;" />
                                        </VBox>

                                        <!-- Row 1: Type & Priorité -->
                                        <Label text="Type *" style="-fx-font-weight: bold; -fx-text-fill: #555;" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                        <VBox spacing="3" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                            <ComboBox fx:id="typeDemandeCombo" maxWidth="1.7976931348623157E308"
                                                      promptText="Sélectionnez le type" style="-fx-background-radius: 8;" />
                                            <Label fx:id="typeError" text="" style="-fx-text-fill: #e74c3c; -fx-font-size: 11;" />
                                        </VBox>

                                        <Label text="Priorité *" style="-fx-font-weight: bold; -fx-text-fill: #555;" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                                        <VBox spacing="3" GridPane.columnIndex="3" GridPane.rowIndex="1">
                                            <ComboBox fx:id="prioriteCombo" maxWidth="1.7976931348623157E308"
                                                      promptText="Sélectionnez" style="-fx-background-radius: 8;" />
                                            <Label fx:id="prioriteError" text="" style="-fx-text-fill: #e74c3c; -fx-font-size: 11;" />
                                        </VBox>

                                        <!-- Row 2: Status & Date -->
                                        <Label text="Statut *" style="-fx-font-weight: bold; -fx-text-fill: #555;" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                        <VBox spacing="3" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                            <ComboBox fx:id="statusCombo" maxWidth="1.7976931348623157E308" style="-fx-background-radius: 8;" />
                                            <Label fx:id="statusError" text="" style="-fx-text-fill: #e74c3c; -fx-font-size: 11;" />
                                        </VBox>

                                        <Label text="Date *" style="-fx-font-weight: bold; -fx-text-fill: #555;" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                                        <VBox spacing="3" GridPane.columnIndex="3" GridPane.rowIndex="2">
                                            <DatePicker fx:id="dateCreationPicker" maxWidth="1.7976931348623157E308" style="-fx-background-radius: 8;" />
                                            <Label fx:id="dateError" text="" style="-fx-text-fill: #e74c3c; -fx-font-size: 11;" />
                                        </VBox>

                                        <!-- Row 3: Destination (conditionally visible) -->
                                        <Label fx:id="destinationLabel" text="Destination" style="-fx-font-weight: bold; -fx-text-fill: #555;"
                                               GridPane.columnIndex="0" GridPane.rowIndex="3"
                                               visible="false" managed="false" />
                                        <HBox fx:id="destinationContainer" spacing="8" alignment="CENTER_LEFT"
                                              GridPane.columnIndex="1" GridPane.columnSpan="3" GridPane.rowIndex="3"
                                              visible="false" managed="false">
                                            <children>
                                                <VBox spacing="3" HBox.hgrow="ALWAYS" maxWidth="450">
                                                    <TextField fx:id="destinationField"
                                                               promptText="Cliquez sur 📍 pour choisir"
                                                               editable="false"
                                                               style="-fx-background-radius: 8; -fx-background-color: #f8f9fa;" />
                                                    <Label fx:id="destinationError" text=""
                                                           style="-fx-text-fill: #e74c3c; -fx-font-size: 11;" />
                                                </VBox>
                                                <Button fx:id="mapButton" onAction="#ouvrirCarte"
                                                        prefHeight="38" prefWidth="50"
                                                        style="-fx-background-color: #4A5DEF; -fx-background-radius: 8; -fx-cursor: hand;">
                                                    <graphic>
                                                        <Label text="📍" style="-fx-font-size: 18;" />
                                                    </graphic>
                                                    <tooltip>
                                                        <Tooltip text="Modifier la destination sur la carte" />
                                                    </tooltip>
                                                </Button>
                                            </children>
                                        </HBox>

                                        <!-- Row 4: Description -->
                                        <Label text="Description *" style="-fx-font-weight: bold; -fx-text-fill: #555;"
                                               GridPane.columnIndex="0" GridPane.rowIndex="4" GridPane.valignment="TOP" />
                                        <VBox spacing="3" GridPane.columnIndex="1" GridPane.columnSpan="3" GridPane.rowIndex="4">
                                            <TextArea fx:id="descriptionArea" prefRowCount="4"
                                                      promptText="Description de la demande..."
                                                      wrapText="true" style="-fx-background-radius: 8;" />
                                            <Label fx:id="descriptionError" text="" style="-fx-text-fill: #e74c3c; -fx-font-size: 11;" />
                                        </VBox>
                                    </children>
                                </GridPane>
                            </children>
                        </VBox>

                        <!-- Dynamic Details Card -->
                        <TitledPane fx:id="detailsPane" animated="false" collapsible="false"
                                    text="📎 Détails Spécifiques"
                                    style="-fx-background-color: white;">
                            <content>
                                <VBox fx:id="dynamicFieldsContainer" spacing="15.0"
                                      style="-fx-background-color: white; -fx-padding: 20;">
                                    <children>
                                        <Label text="💡 Sélectionnez un type de demande pour voir les champs spécifiques"
                                               style="-fx-text-fill: #888; -fx-font-style: italic; -fx-font-size: 13;" />
                                    </children>
                                </VBox>
                            </content>
                        </TitledPane>

                        <!-- Action Buttons -->
                        <HBox alignment="CENTER" spacing="20.0">
                            <padding>
                                <Insets top="15.0" bottom="10.0" />
                            </padding>
                            <children>
                                <Button onAction="#modifierDemande" prefWidth="250.0" prefHeight="50.0"
                                        style="-fx-background-color: #3498db; -fx-text-fill: white;
                                               -fx-background-radius: 10; -fx-cursor: hand;"
                                        text="💾 Enregistrer les Modifications">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Button>
                                <Button onAction="#retourListe" prefWidth="140.0" prefHeight="50.0"
                                        style="-fx-background-color: #95a5a6; -fx-text-fill: white;
                                               -fx-background-radius: 10; -fx-cursor: hand;"
                                        text="❌ Annuler">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Button>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>