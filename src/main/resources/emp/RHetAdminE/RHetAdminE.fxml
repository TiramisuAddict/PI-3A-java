<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.effect.Blend?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane" prefHeight="573.0" prefWidth="918.0"
            stylesheets="@/customTheme.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.employers.RHetAdminE.RHetAdminE">
    <left>
        <VBox fx:id="sidebar" prefWidth="68.0" styleClass="sidebar" BorderPane.alignment="CENTER">
            <children>
                <Button fx:id="btnToggle" maxWidth="Infinity" onAction="#handleToggleSidebar" styleClass="nav-button, logo-button">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="20">
                            <ImageView fitHeight="22" fitWidth="22" preserveRatio="true">
                                <image>
                                    <Image url="@../../icons/logo.png"/>
                                </image>
                                <effect><Blend/></effect>
                            </ImageView>
                            <Label style="-fx-font-weight: bold;"
                                   styleClass="nav-label" text="Momentum"/>
                        </HBox>
                    </graphic>
                    <VBox.margin>
                        <Insets bottom="20.0" top="10.0"/>
                    </VBox.margin>
                </Button>

                <VBox spacing="10.0">
                    <children>
                        <VBox fx:id="userCard" spacing="10.0"
                              visible="false" managed="false"
                              onMouseClicked="#showProfil"
                              style="-fx-background-color: linear-gradient(to right, #667eea 0%, #764ba2 100%); -fx-background-radius: 8;-fx-padding: 12;-fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 2);">
                            <VBox.margin>
                                <Insets bottom="20.0" left="10.0" right="10.0" top="5.0"/>
                            </VBox.margin>
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <StackPane fx:id="avatarSidebar" prefWidth="40.0" prefHeight="40.0" minWidth="40.0" minHeight="40.0" maxWidth="40.0" maxHeight="40.0"/>
                                        <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Bienvenue" style="-fx-font-size: 10px;-fx-text-fill: rgba(255,255,255,0.7);"/>
                                                <Label fx:id="lblEmployeCourant" text="Non connecté" style="-fx-font-weight: bold;-fx-font-size: 13px; -fx-text-fill: white;" wrapText="true"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                                <Button fx:id="btnDeconnexion" text="Déconnecter" onAction="#handleDeconnexion" maxWidth="Infinity" prefHeight="28.0" style="-fx-background-color: rgba(255,255,255,0.25);-fx-text-fill: white;-fx-font-size: 10px;-fx-background-radius: 6;-fx-cursor: hand;"/>
                            </children>
                        </VBox>

                        <Button fx:id="btnHome" maxWidth="Infinity" onAction="#showHome" styleClass="nav-button, nav-active">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="20">
                                    <StackPane maxWidth="25" minWidth="25">
                                        <ImageView fitHeight="22" fitWidth="22" preserveRatio="true">
                                            <image><Image url="@../../icons/home.png"/></image>
                                        </ImageView>
                                    </StackPane>
                                    <Label styleClass="nav-label" text="Home"/>
                                </HBox>
                            </graphic>
                        </Button>

                        <Button fx:id="btnFormation" maxWidth="Infinity" onAction="#showFormation" styleClass="nav-button">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="20">
                                    <StackPane maxWidth="25" minWidth="25">
                                        <ImageView fitHeight="22" fitWidth="22" preserveRatio="true">
                                            <image><Image url="@../../icons/edit.png"/></image>
                                        </ImageView>
                                    </StackPane>
                                    <Label styleClass="nav-label" text="Formations"/>
                                </HBox>
                            </graphic>
                        </Button>

                        <Button fx:id="btnDemande" maxWidth="Infinity" onAction="#showDemande" styleClass="nav-button">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="20">
                                    <StackPane maxWidth="25" minWidth="25">
                                        <ImageView fitHeight="22" fitWidth="22" preserveRatio="true">
                                            <image><Image url="@../../icons/send.png"/></image>
                                        </ImageView>
                                    </StackPane>
                                    <Label styleClass="nav-label" text="Demandes"/>
                                </HBox>
                            </graphic>
                        </Button>

                        <Button fx:id="btnEmployer" maxWidth="Infinity" onAction="#showEmployer" styleClass="nav-button">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="20">
                                    <StackPane maxWidth="25" minWidth="25">
                                        <ImageView fitHeight="22" fitWidth="22" preserveRatio="true">
                                            <image><Image url="@../../icons/users.png"/></image>
                                        </ImageView>
                                    </StackPane>
                                    <Label styleClass="nav-label" text="Utilisateurs"/>
                                </HBox>
                            </graphic>
                        </Button>

                        <Button fx:id="btnProjet" maxWidth="Infinity"
                                onAction="#showProjet" styleClass="nav-button">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="20">
                                    <StackPane maxWidth="25" minWidth="25">
                                        <ImageView fitHeight="22" fitWidth="22" preserveRatio="true">
                                            <image><Image url="@../../icons/layout.png"/></image>
                                        </ImageView>
                                    </StackPane>
                                    <Label styleClass="nav-label" text="Projets"/>
                                </HBox>
                            </graphic>
                        </Button>

                        <Button fx:id="btnOffre" maxWidth="Infinity" onAction="#showOffres" styleClass="nav-button">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="20">
                                    <StackPane maxWidth="25" minWidth="25">
                                        <ImageView fitHeight="22" fitWidth="22" preserveRatio="true">
                                            <image><Image url="@../../icons/share.png"/></image>
                                        </ImageView>
                                    </StackPane>
                                    <Label styleClass="nav-label" text="Offres d'emploi"/>
                                </HBox>
                            </graphic>
                        </Button>
                    </children>
                </VBox>
            </children>
        </VBox>
    </left>

    <!-- ═══════ CENTER: TOP BAR + CONTENT ═══════ -->
    <center>
        <VBox BorderPane.alignment="CENTER">
            <!-- ══════ TOP BAR (FIXE) ══════ -->
            <HBox fx:id="topBar" alignment="CENTER_RIGHT" spacing="15.0"
                  style="-fx-background-color: -color-bg-default;
                         -fx-border-width: 0 0 1 0;
                         -fx-padding: 8 25 8 25;
                         -fx-min-height: 50;
                         -fx-max-height: 50;">
                <children>
                    <Region HBox.hgrow="ALWAYS"/>

                    <!-- Notification -->
                    <StackPane fx:id="notifContainer"
                               style="-fx-cursor: hand;"
                               prefWidth="36" prefHeight="36">
                        <children>
                            <ImageView fitHeight="18" fitWidth="18" preserveRatio="true">
                                <image>
                                    <Image url="@../../icons/bell.png"/>
                                </image>
                            </ImageView>
                            <Label fx:id="lblNotifBadge" text="0"
                                   visible="false" managed="false"
                                   style="-fx-background-color: #EF4444;
                                          -fx-text-fill: white;
                                          -fx-font-size: 9px;
                                          -fx-font-weight: bold;
                                          -fx-padding: 1 4 1 4;
                                          -fx-background-radius: 10;
                                          -fx-min-width: 16;
                                          -fx-min-height: 16;
                                          -fx-alignment: center;"
                                   StackPane.alignment="TOP_RIGHT">
                                <StackPane.margin>
                                    <Insets top="-3.0" right="-3.0"/>
                                </StackPane.margin>
                            </Label>
                        </children>
                    </StackPane>

                    <!-- Image profil -->
                    <ImageView fx:id="imgProfilTopBar"
                               fitHeight="34" fitWidth="34"
                               preserveRatio="false"
                               onMouseClicked="#showProfil"
                               style="-fx-cursor: hand;"/>
                </children>
            </HBox>

            <!-- ══════ CONTENT AREA ══════ -->
            <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS"/>
        </VBox>
    </center>
</BorderPane>