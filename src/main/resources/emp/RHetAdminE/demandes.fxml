<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="1200.0"
            stylesheets="@/css/customTheme.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.employers.RHetAdminE.DemandesController">
    <children>
        <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE"
                 AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0"
                 AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
            <tabs>
                <!-- ═══════════════════════════════════════════════════════════════════ -->
                <!-- TAB 1: DEMANDES -->
                <!-- ═══════════════════════════════════════════════════════════════════ -->
                <Tab text="📋 Demandes" closable="false">
                    <HBox spacing="15">
                        <padding><Insets bottom="15" left="15" right="15" top="15" /></padding>
                        <children>
                            <!-- LEFT PANEL: Table + Pagination -->
                            <VBox spacing="10" HBox.hgrow="ALWAYS">
                                <children>
                                    <Label text="Gestion des Demandes" styleClass="title-1">
                                        <font><Font name="System Bold" size="24" /></font>
                                    </Label>

                                    <!-- Search Bar -->
                                    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="search-bar">
                                        <padding><Insets top="5" bottom="5" /></padding>
                                        <children>
                                            <Label text="🔍" style="-fx-font-size: 16;" />
                                            <TextField fx:id="rechercheField" prefWidth="300"
                                                       promptText="Rechercher par titre, catégorie, type..."
                                                       styleClass="text-field" />
                                            <Region HBox.hgrow="ALWAYS" />
                                            <Label fx:id="pageInfoLabel" text="Page 1/1"
                                                   style="-fx-text-fill: #666; -fx-font-size: 12;" />
                                        </children>
                                    </HBox>

                                    <!-- TABLE CONTAINER - NO SCROLL -->
                                    <VBox fx:id="tableContainer" VBox.vgrow="ALWAYS" spacing="0"
                                          style="-fx-background-color: white; -fx-background-radius: 8;">
                                        <children>
                                            <!-- TABLE - Fixed row height, no scroll -->
                                            <TableView fx:id="demandesTable"
                                                       VBox.vgrow="ALWAYS"
                                                       fixedCellSize="45"
                                                       style="-fx-background-color: transparent;">
                                                <columns>
                                                    <TableColumn fx:id="titreCol" prefWidth="150" text="Titre" />
                                                    <TableColumn fx:id="categorieCol" prefWidth="100" text="Catégorie" />
                                                    <TableColumn fx:id="typeCol" prefWidth="100" text="Type" />
                                                    <TableColumn fx:id="prioriteCol" prefWidth="80" text="Priorité" />
                                                    <TableColumn fx:id="statusCol" prefWidth="90" text="Statut" />
                                                    <TableColumn fx:id="dateCol" prefWidth="90" text="Date" />
                                                    <TableColumn fx:id="actionsCol" prefWidth="120" minWidth="100" text="Actions" />
                                                </columns>
                                                <columnResizePolicy>
                                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                                </columnResizePolicy>
                                            </TableView>

                                            <!-- PAGINATION BAR -->
                                            <HBox fx:id="paginationBar" alignment="CENTER" spacing="5"
                                                  style="-fx-padding: 12 15; -fx-background-color: #f8f9fa;
                                                         -fx-border-color: #e0e0e0; -fx-border-width: 1 0 0 0;
                                                         -fx-background-radius: 0 0 8 8;">
                                                <children>
                                                    <Button fx:id="btnFirstPage" text="⏮" onAction="#goToFirstPage"
                                                            minWidth="32" minHeight="32"
                                                            style="-fx-background-color: #f0f0f0; -fx-background-radius: 6; -fx-cursor: hand;" />
                                                    <Button fx:id="btnPrevPage" text="◀" onAction="#goToPrevPage"
                                                            minWidth="32" minHeight="32"
                                                            style="-fx-background-color: #f0f0f0; -fx-background-radius: 6; -fx-cursor: hand;" />

                                                    <HBox fx:id="pageButtonsContainer" spacing="3" alignment="CENTER" />

                                                    <Button fx:id="btnNextPage" text="▶" onAction="#goToNextPage"
                                                            minWidth="32" minHeight="32"
                                                            style="-fx-background-color: #f0f0f0; -fx-background-radius: 6; -fx-cursor: hand;" />
                                                    <Button fx:id="btnLastPage" text="⏭" onAction="#goToLastPage"
                                                            minWidth="32" minHeight="32"
                                                            style="-fx-background-color: #f0f0f0; -fx-background-radius: 6; -fx-cursor: hand;" />

                                                    <Region HBox.hgrow="ALWAYS" />

                                                    <!-- Hidden combo - auto calculated -->
                                                    <ComboBox fx:id="pageSizeCombo" visible="false" managed="false" />
                                                </children>
                                            </HBox>
                                        </children>
                                    </VBox>
                                </children>
                            </VBox>

                            <!-- RIGHT PANEL: Details -->
                            <VBox spacing="10" minWidth="350" maxWidth="400">
                                <children>
                                    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                                                style="-fx-background-color: transparent; -fx-background: transparent;">
                                        <content>
                                            <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 8;">
                                                <padding><Insets bottom="15" left="15" right="15" top="15" /></padding>
                                                <children>
                                                    <!-- Placeholder -->
                                                    <VBox fx:id="placeholderBox" alignment="CENTER" spacing="10"
                                                          style="-fx-padding: 50;">
                                                        <children>
                                                            <Label text="📋" style="-fx-font-size: 48;" />
                                                            <Label text="Sélectionnez une demande"
                                                                   style="-fx-font-size: 14; -fx-text-fill: #999;" />
                                                            <Label text="pour voir ses détails"
                                                                   style="-fx-font-size: 12; -fx-text-fill: #bbb;" />
                                                        </children>
                                                    </VBox>

                                                    <!-- Details Content -->
                                                    <VBox fx:id="detailsContent" spacing="10" visible="false" managed="false">
                                                        <children>
                                                            <Label fx:id="detailTitreLabel"
                                                                   style="-fx-font-size: 16; -fx-font-weight: bold;"
                                                                   wrapText="true" />
                                                            <Separator />

                                                            <GridPane hgap="10" vgap="8">
                                                                <columnConstraints>
                                                                    <ColumnConstraints minWidth="80" />
                                                                    <ColumnConstraints hgrow="ALWAYS" />
                                                                </columnConstraints>
                                                                <Label text="Catégorie:" style="-fx-font-weight: bold; -fx-text-fill: #666;"
                                                                       GridPane.rowIndex="0" />
                                                                <Label fx:id="detailCategorieLabel" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                                                <Label text="Type:" style="-fx-font-weight: bold; -fx-text-fill: #666;"
                                                                       GridPane.rowIndex="1" />
                                                                <Label fx:id="detailTypeLabel" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                                                <Label text="Priorité:" style="-fx-font-weight: bold; -fx-text-fill: #666;"
                                                                       GridPane.rowIndex="2" />
                                                                <Label fx:id="detailPrioriteLabel" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                                                <Label text="Statut:" style="-fx-font-weight: bold; -fx-text-fill: #666;"
                                                                       GridPane.rowIndex="3" />
                                                                <Label fx:id="detailStatusLabel" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                                                                <Label text="Date:" style="-fx-font-weight: bold; -fx-text-fill: #666;"
                                                                       GridPane.rowIndex="4" />
                                                                <Label fx:id="detailDateLabel" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                                                            </GridPane>

                                                            <Separator />
                                                            <Label text="📝 Description" style="-fx-font-weight: bold; -fx-text-fill: #666;" />
                                                            <Label fx:id="detailDescriptionLabel" wrapText="true"
                                                                   style="-fx-padding: 10; -fx-background-color: #f8f9fa; -fx-background-radius: 6;" />

                                                            <Separator />
                                                            <Label text="📎 Détails Spécifiques" style="-fx-font-weight: bold; -fx-text-fill: #666;" />
                                                            <VBox fx:id="detailSpecificContainer" spacing="5"
                                                                  style="-fx-padding: 10; -fx-background-color: #f8f9fa; -fx-background-radius: 6;" />

                                                            <Separator />

                                                            <!-- Actions -->
                                                            <HBox alignment="CENTER" spacing="10">
                                                                <Button onAction="#generateDocument" text="📄 Générer Doc"
                                                                        style="-fx-background-color: #4A5DEF; -fx-text-fill: white;
                                                                               -fx-background-radius: 6; -fx-padding: 8 15; -fx-cursor: hand;" />
                                                                <Button fx:id="avancerBtn" onAction="#ouvrirAvancer" text="⚡ Avancer"
                                                                        style="-fx-background-color: #f39c12; -fx-text-fill: white;
                                                                               -fx-background-radius: 6; -fx-padding: 8 15; -fx-cursor: hand;" />
                                                            </HBox>

                                                            <Separator />
                                                            <Label text="📜 Historique" style="-fx-font-weight: bold; -fx-text-fill: #666;" />
                                                            <VBox fx:id="historiqueContainer" spacing="8" />
                                                        </children>
                                                    </VBox>
                                                </children>
                                            </VBox>
                                        </content>
                                    </ScrollPane>
                                </children>
                            </VBox>
                        </children>
                    </HBox>
                </Tab>

                <!-- ═══════════════════════════════════════════════════════════════════ -->
                <!-- TAB 2: STATISTIQUES & PERFORMANCE -->
                <!-- ═══════════════════════════════════════════════════════════════════ -->
                <Tab text="📊 Statistiques" closable="false">
                    <ScrollPane fitToWidth="true" style="-fx-background-color: #f5f6fa; -fx-background: #f5f6fa;">
                        <content>
                            <VBox spacing="25" style="-fx-padding: 30; -fx-background-color: #f5f6fa;">
                                <!-- Header -->
                                <HBox alignment="CENTER_LEFT" spacing="15">
                                    <Label text="📊 Tableau de Bord" style="-fx-font-size: 24; -fx-font-weight: bold;" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Button onAction="#refreshStatistiques" text="🔄 Actualiser"
                                            style="-fx-background-color: #4A5DEF; -fx-text-fill: white;
                                                   -fx-background-radius: 6; -fx-padding: 8 15; -fx-cursor: hand;" />
                                </HBox>

                                <!-- Performance Cards -->
                                <Label text="🎯 Performance RH" style="-fx-font-size: 18; -fx-font-weight: bold;" />

                                <HBox spacing="20" alignment="CENTER">
                                    <!-- Performance Score -->
                                    <VBox alignment="CENTER" spacing="10" HBox.hgrow="ALWAYS"
                                          style="-fx-background-color: linear-gradient(to bottom right, #4A5DEF, #3944D5);
                                                 -fx-padding: 25; -fx-background-radius: 12;">
                                        <Label text="🏆" style="-fx-font-size: 36;" />
                                        <Label fx:id="lblPerformanceScore" text="0%"
                                               style="-fx-font-size: 48; -fx-font-weight: bold; -fx-text-fill: white;" />
                                        <Label text="Score de Performance"
                                               style="-fx-font-size: 14; -fx-text-fill: rgba(255,255,255,0.8);" />
                                        <Label fx:id="lblPerformanceGrade" text="--"
                                               style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: white;
                                                      -fx-background-color: rgba(255,255,255,0.2); -fx-padding: 5 15;
                                                      -fx-background-radius: 15;" />
                                    </VBox>

                                    <!-- On-Time Rate -->
                                    <VBox alignment="CENTER" spacing="10" HBox.hgrow="ALWAYS"
                                          style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 12;
                                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                                        <Label text="⏱️" style="-fx-font-size: 36;" />
                                        <Label fx:id="lblOnTimeRate" text="0%"
                                               style="-fx-font-size: 42; -fx-font-weight: bold; -fx-text-fill: #27ae60;" />
                                        <Label text="Traitement à Temps" style="-fx-font-size: 12; -fx-text-fill: #666;" />
                                        <HBox spacing="5" alignment="CENTER">
                                            <Label fx:id="lblOnTimeCount" text="0"
                                                   style="-fx-font-weight: bold; -fx-text-fill: #27ae60;" />
                                            <Label text="/" style="-fx-text-fill: #999;" />
                                            <Label fx:id="lblTotalProcessed" text="0" style="-fx-text-fill: #999;" />
                                        </HBox>
                                    </VBox>

                                    <!-- Late Rate -->
                                    <VBox alignment="CENTER" spacing="10" HBox.hgrow="ALWAYS"
                                          style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 12;
                                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                                        <Label text="⚠️" style="-fx-font-size: 36;" />
                                        <Label fx:id="lblLateRate" text="0%"
                                               style="-fx-font-size: 42; -fx-font-weight: bold; -fx-text-fill: #e74c3c;" />
                                        <Label text="En Retard" style="-fx-font-size: 12; -fx-text-fill: #666;" />
                                        <HBox spacing="5" alignment="CENTER">
                                            <Label fx:id="lblLateCount" text="0"
                                                   style="-fx-font-weight: bold; -fx-text-fill: #e74c3c;" />
                                            <Label text="demandes" style="-fx-text-fill: #999;" />
                                        </HBox>
                                    </VBox>

                                    <!-- Average Response Time -->
                                    <VBox alignment="CENTER" spacing="10" HBox.hgrow="ALWAYS"
                                          style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 12;
                                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                                        <Label text="📈" style="-fx-font-size: 36;" />
                                        <Label fx:id="lblAvgResponseTime" text="0h"
                                               style="-fx-font-size: 42; -fx-font-weight: bold; -fx-text-fill: #3498db;" />
                                        <Label text="Temps Moyen" style="-fx-font-size: 12; -fx-text-fill: #666;" />
                                        <Label fx:id="lblResponseTimeStatus" text="--"
                                               style="-fx-font-size: 11; -fx-text-fill: #999;" />
                                    </VBox>
                                </HBox>

                                <!-- Performance Details -->
                                <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12;">
                                    <Label text="📋 Détails de Performance" style="-fx-font-weight: bold; -fx-font-size: 14;" />

                                    <HBox spacing="20">
                                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                                            <HBox>
                                                <Label text="Haute Priorité" style="-fx-font-size: 11;" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Label fx:id="lblHighPriorityTime" text="--"
                                                       style="-fx-font-size: 11; -fx-text-fill: #666;" />
                                            </HBox>
                                            <ProgressBar fx:id="progressHighPriority" progress="0" prefWidth="9999"
                                                         style="-fx-accent: #e74c3c;" />
                                        </VBox>

                                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                                            <HBox>
                                                <Label text="Priorité Normale" style="-fx-font-size: 11;" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Label fx:id="lblNormalPriorityTime" text="--"
                                                       style="-fx-font-size: 11; -fx-text-fill: #666;" />
                                            </HBox>
                                            <ProgressBar fx:id="progressNormalPriority" progress="0" prefWidth="9999"
                                                         style="-fx-accent: #3498db;" />
                                        </VBox>

                                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                                            <HBox>
                                                <Label text="Basse Priorité" style="-fx-font-size: 11;" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Label fx:id="lblLowPriorityTime" text="--"
                                                       style="-fx-font-size: 11; -fx-text-fill: #666;" />
                                            </HBox>
                                            <ProgressBar fx:id="progressLowPriority" progress="0" prefWidth="9999"
                                                         style="-fx-accent: #27ae60;" />
                                        </VBox>
                                    </HBox>

                                    <Separator />

                                    <!-- SLA Compliance -->
                                    <HBox spacing="30" alignment="CENTER">
                                        <VBox alignment="CENTER" spacing="3">
                                            <Label text="SLA Haute (24h)" style="-fx-font-size: 11; -fx-text-fill: #666;" />
                                            <Label fx:id="lblSlaHigh" text="0%"
                                                   style="-fx-font-size: 18; -fx-font-weight: bold;" />
                                        </VBox>
                                        <Separator orientation="VERTICAL" />
                                        <VBox alignment="CENTER" spacing="3">
                                            <Label text="SLA Normal (48h)" style="-fx-font-size: 11; -fx-text-fill: #666;" />
                                            <Label fx:id="lblSlaNormal" text="0%"
                                                   style="-fx-font-size: 18; -fx-font-weight: bold;" />
                                        </VBox>
                                        <Separator orientation="VERTICAL" />
                                        <VBox alignment="CENTER" spacing="3">
                                            <Label text="SLA Basse (72h)" style="-fx-font-size: 11; -fx-text-fill: #666;" />
                                            <Label fx:id="lblSlaLow" text="0%"
                                                   style="-fx-font-size: 18; -fx-font-weight: bold;" />
                                        </VBox>
                                        <Separator orientation="VERTICAL" />
                                        <VBox alignment="CENTER" spacing="3">
                                            <Label text="En Attente" style="-fx-font-size: 11; -fx-text-fill: #666;" />
                                            <Label fx:id="lblPendingCount" text="0"
                                                   style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #f39c12;" />
                                        </VBox>
                                    </HBox>
                                </VBox>

                                <Separator />

                                <!-- Basic Statistics -->
                                <Label text="📈 Vue d'Ensemble" style="-fx-font-size: 18; -fx-font-weight: bold;" />

                                <HBox spacing="20" alignment="CENTER">
                                    <VBox alignment="CENTER" spacing="10" HBox.hgrow="ALWAYS"
                                          style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 10;
                                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                                        <Label text="📋" style="-fx-font-size: 32;" />
                                        <Label fx:id="lblTotalDemandes" text="0"
                                               style="-fx-font-size: 42; -fx-font-weight: bold; -fx-text-fill: #3498db;" />
                                        <Label text="Total Demandes" style="-fx-font-size: 13; -fx-text-fill: #666;" />
                                    </VBox>

                                    <VBox alignment="CENTER" spacing="10" HBox.hgrow="ALWAYS"
                                          style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 10;
                                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                                        <Label text="📝" style="-fx-font-size: 32;" />
                                        <Label fx:id="lblTotalHistorique" text="0"
                                               style="-fx-font-size: 42; -fx-font-weight: bold; -fx-text-fill: #9b59b6;" />
                                        <Label text="Actions Effectuées" style="-fx-font-size: 13; -fx-text-fill: #666;" />
                                    </VBox>

                                    <VBox alignment="CENTER" spacing="10" HBox.hgrow="ALWAYS"
                                          style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 10;
                                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                                        <Label text="✅" style="-fx-font-size: 32;" />
                                        <Label fx:id="lblDemandesResolues" text="0"
                                               style="-fx-font-size: 42; -fx-font-weight: bold; -fx-text-fill: #27ae60;" />
                                        <Label text="Résolues" style="-fx-font-size: 13; -fx-text-fill: #666;" />
                                    </VBox>

                                    <VBox alignment="CENTER" spacing="10" HBox.hgrow="ALWAYS"
                                          style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 10;
                                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                                        <Label text="🔥" style="-fx-font-size: 32;" />
                                        <Label fx:id="lblUrgentDemandes" text="0"
                                               style="-fx-font-size: 42; -fx-font-weight: bold; -fx-text-fill: #e74c3c;" />
                                        <Label text="Urgentes" style="-fx-font-size: 13; -fx-text-fill: #666;" />
                                    </VBox>
                                </HBox>

                                <Separator />

                                <!-- Stats by Status -->
                                <Label text="📌 Par Statut" style="-fx-font-size: 16; -fx-font-weight: bold;" />
                                <HBox fx:id="statutStatsContainer" spacing="15" alignment="CENTER" />

                                <Separator />

                                <!-- Stats by Priority -->
                                <Label text="🔥 Par Priorité" style="-fx-font-size: 16; -fx-font-weight: bold;" />
                                <HBox fx:id="prioriteStatsContainer" spacing="15" alignment="CENTER" />

                                <Separator />

                                <!-- Stats by Type -->
                                <Label text="📂 Par Type" style="-fx-font-size: 16; -fx-font-weight: bold;" />
                                <HBox fx:id="typeStatsContainer" spacing="15" alignment="CENTER" />

                                <Separator />

                                <!-- Stats by Category -->
                                <Label text="🏷️ Par Catégorie" style="-fx-font-size: 16; -fx-font-weight: bold;" />
                                <HBox fx:id="categorieStatsContainer" spacing="15" alignment="CENTER" />
                            </VBox>
                        </content>
                    </ScrollPane>
                </Tab>
            </tabs>
        </TabPane>
    </children>
</AnchorPane>