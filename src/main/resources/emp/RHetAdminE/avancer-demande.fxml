<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="550.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.employers.RHetAdminE.AvancerDemandeController">
    <children>
        <ScrollPane fitToWidth="true" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <content>
                <VBox spacing="15.0">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <children>
                        <!-- Header -->
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Button onAction="#retourListe" text="← Retour" style="-fx-background-color: #95a5a6; -fx-text-fill: white;">
                                    <font><Font name="System Bold" size="12.0" /></font>
                                </Button>
                                <Label text="Avancer le Statut" textFill="#2c3e50">
                                    <font><Font name="System Bold" size="22.0" /></font>
                                </Label>
                            </children>
                        </HBox>

                        <!-- Current Demande Info -->
                        <TitledPane animated="false" collapsible="false" text="Informations de la Demande">
                            <content>
                                <GridPane hgap="10.0" vgap="10.0">
                                    <padding>
                                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                                    </padding>
                                    <columnConstraints>
                                        <ColumnConstraints minWidth="120.0" />
                                        <ColumnConstraints hgrow="ALWAYS" />
                                    </columnConstraints>
                                    <children>
                                        <Label text="Titre:" style="-fx-font-weight: bold;" GridPane.rowIndex="0" />
                                        <Label fx:id="infoTitreLabel" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                        <Label text="Type:" style="-fx-font-weight: bold;" GridPane.rowIndex="1" />
                                        <Label fx:id="infoTypeLabel" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                        <Label text="Priorité:" style="-fx-font-weight: bold;" GridPane.rowIndex="2" />
                                        <Label fx:id="infoPrioriteLabel" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                        <Label text="Statut Actuel:" style="-fx-font-weight: bold;" GridPane.rowIndex="3" />
                                        <Label fx:id="infoStatusLabel" style="-fx-font-size: 14; -fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                    </children>
                                </GridPane>
                            </content>
                        </TitledPane>

                        <!-- Status Flow -->
                        <TitledPane animated="false" collapsible="false" text="Flux de Statut">
                            <content>
                                <HBox fx:id="statusFlowContainer" alignment="CENTER" spacing="5.0">
                                    <padding>
                                        <Insets bottom="15.0" left="10.0" right="10.0" top="15.0" />
                                    </padding>
                                </HBox>
                            </content>
                        </TitledPane>

                        <!-- Change Status Form -->
                        <TitledPane animated="false" collapsible="false" text="Changer le Statut">
                            <content>
                                <VBox spacing="10.0">
                                    <padding>
                                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                                    </padding>
                                    <children>
                                        <!-- Nouveau Statut -->
                                        <HBox spacing="10.0" alignment="CENTER_LEFT">
                                            <children>
                                                <Label text="Nouveau Statut: *" style="-fx-font-weight: bold;" minWidth="120.0" />
                                                <VBox>
                                                    <ComboBox fx:id="nouveauStatutCombo" prefWidth="250.0" promptText="Sélectionnez le nouveau statut" />
                                                    <Label fx:id="statutError" text="" style="-fx-text-fill: red; -fx-font-size: 11;" />
                                                </VBox>
                                            </children>
                                        </HBox>

                                        <!-- Acteur -->
                                        <HBox spacing="10.0" alignment="CENTER_LEFT">
                                            <children>
                                                <Label text="Acteur: *" style="-fx-font-weight: bold;" minWidth="120.0" />
                                                <VBox>
                                                    <ComboBox fx:id="acteurCombo" prefWidth="250.0" promptText="Sélectionnez l'acteur" />
                                                    <Label fx:id="acteurError" text="" style="-fx-text-fill: red; -fx-font-size: 11;" />
                                                </VBox>
                                            </children>
                                        </HBox>

                                        <!-- Commentaire -->
                                        <HBox spacing="10.0" alignment="TOP_LEFT">
                                            <children>
                                                <Label text="Commentaire: *" style="-fx-font-weight: bold;" minWidth="120.0" />
                                                <VBox HBox.hgrow="ALWAYS">
                                                    <TextArea fx:id="commentaireArea" prefRowCount="3" promptText="Ajoutez un commentaire sur ce changement..." wrapText="true" />
                                                    <Label fx:id="commentaireError" text="" style="-fx-text-fill: red; -fx-font-size: 11;" />
                                                </VBox>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </content>
                        </TitledPane>

                        <!-- Submit -->
                        <HBox alignment="CENTER" spacing="10.0">
                            <padding>
                                <Insets top="5.0" bottom="5.0" />
                            </padding>
                            <children>
                                <Button onAction="#avancerStatut" prefWidth="220.0" prefHeight="40.0" style="-fx-background-color: #f39c12; -fx-text-fill: white;" text="⚡ Confirmer le Changement">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Button>
                                <Button onAction="#retourListe" prefWidth="120.0" prefHeight="40.0" style="-fx-background-color: #95a5a6; -fx-text-fill: white;" text="Annuler">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Button>
                            </children>
                        </HBox>

                        <!-- Historique Table -->
                        <TitledPane animated="false" collapsible="false" text="Historique des Changements">
                            <content>
                                <TableView fx:id="historiqueTable" prefHeight="200.0">
                                    <columns>
                                        <TableColumn fx:id="ancienStatutCol" prefWidth="100.0" text="Ancien Statut" />
                                        <TableColumn fx:id="nouveauStatutCol" prefWidth="100.0" text="Nouveau Statut" />
                                        <TableColumn fx:id="acteurCol" prefWidth="100.0" text="Acteur" />
                                        <TableColumn fx:id="dateActionCol" prefWidth="130.0" text="Date" />
                                        <TableColumn fx:id="commentaireCol" prefWidth="250.0" text="Commentaire" />
                                    </columns>
                                </TableView>
                            </content>
                        </TitledPane>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>