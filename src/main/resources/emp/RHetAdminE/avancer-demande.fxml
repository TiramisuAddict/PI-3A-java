<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="900.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.employers.RHetAdminE.AvancerDemandeController">
    <children>
        <ScrollPane fitToWidth="true"
                    AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0"
                    AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
            <content>
                <VBox spacing="20" style="-fx-padding: 25; -fx-background-color: #f8f9fa;">
                    <children>
                        <!-- Header -->
                        <HBox alignment="CENTER_LEFT" spacing="15">
                            <children>
                                <Button onAction="#retourListe" text="← Retour"
                                        style="-fx-background-color: #95a5a6; -fx-text-fill: white;
                                               -fx-padding: 8 20; -fx-background-radius: 8; -fx-cursor: hand;">
                                    <font><Font name="System Bold" size="13"/></font>
                                </Button>
                                <Label text="⚡ Avancer le Statut de la Demande"
                                       style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                            </children>
                        </HBox>

                        <!-- Demande Info Card -->
                        <VBox spacing="10"
                              style="-fx-background-color: white; -fx-background-radius: 12;
                                     -fx-padding: 20;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 3);">
                            <children>
                                <Label text="📋 Informations de la Demande"
                                       style="-fx-font-weight: bold; -fx-font-size: 15; -fx-text-fill: #2c3e50;" />
                                <Separator />
                                <GridPane hgap="15" vgap="10">
                                    <columnConstraints>
                                        <ColumnConstraints minWidth="110" />
                                        <ColumnConstraints hgrow="ALWAYS" />
                                    </columnConstraints>
                                    <children>
                                        <Label text="Titre:" style="-fx-font-weight: bold; -fx-text-fill: #666;" GridPane.rowIndex="0" />
                                        <Label fx:id="infoTitreLabel" style="-fx-font-size: 14;" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                        <Label text="Type:" style="-fx-font-weight: bold; -fx-text-fill: #666;" GridPane.rowIndex="1" />
                                        <Label fx:id="infoTypeLabel" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                        <Label text="Priorité:" style="-fx-font-weight: bold; -fx-text-fill: #666;" GridPane.rowIndex="2" />
                                        <Label fx:id="infoPrioriteLabel" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                        <Label text="Statut actuel:" style="-fx-font-weight: bold; -fx-text-fill: #666;" GridPane.rowIndex="3" />
                                        <Label fx:id="infoStatusLabel" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                    </children>
                                </GridPane>
                            </children>
                        </VBox>

                        <!-- Status Flow -->
                        <VBox spacing="10"
                              style="-fx-background-color: white; -fx-background-radius: 12;
                                     -fx-padding: 20;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 3);">
                            <children>
                                <Label text="📍 Progression du Statut"
                                       style="-fx-font-weight: bold; -fx-font-size: 15; -fx-text-fill: #2c3e50;" />
                                <HBox fx:id="statusFlowContainer" spacing="8" alignment="CENTER" style="-fx-padding: 15;" />
                            </children>
                        </VBox>

                        <!-- Action Form -->
                        <VBox spacing="15"
                              style="-fx-background-color: white; -fx-background-radius: 12;
                                     -fx-padding: 20;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 3);">
                            <children>
                                <Label text="🔄 Changer le Statut"
                                       style="-fx-font-weight: bold; -fx-font-size: 15; -fx-text-fill: #2c3e50;" />
                                <Separator />

                                <!-- Connected User (AUTO-DETECTED) -->
                                <VBox spacing="5">
                                    <children>
                                        <Label text="Connecté en tant que:" style="-fx-font-weight: bold; -fx-text-fill: #555;" />
                                        <Label fx:id="acteurLabel" text="Chargement..."
                                               style="-fx-font-weight: bold; -fx-font-size: 14;
                                                      -fx-text-fill: #8e44ad;
                                                      -fx-background-color: #f4ecf7;
                                                      -fx-padding: 10 15;
                                                      -fx-background-radius: 8;" />
                                    </children>
                                </VBox>

                                <!-- New Status -->
                                <VBox spacing="5">
                                    <children>
                                        <Label text="Nouveau statut: *" style="-fx-font-weight: bold; -fx-text-fill: #555;" />
                                        <ComboBox fx:id="nouveauStatutCombo" prefWidth="300" promptText="Sélectionnez le nouveau statut" />
                                        <Label fx:id="statutError" style="-fx-text-fill: red; -fx-font-size: 11;" />
                                    </children>
                                </VBox>

                                <!-- Comment -->
                                <VBox spacing="5">
                                    <children>
                                        <Label text="Commentaire / Réponse: *" style="-fx-font-weight: bold; -fx-text-fill: #555;" />
                                        <TextArea fx:id="commentaireArea" prefRowCount="4"
                                                  promptText="Expliquez la raison du changement de statut..." wrapText="true" />
                                        <Label fx:id="commentaireError" style="-fx-text-fill: red; -fx-font-size: 11;" />
                                    </children>
                                </VBox>

                                <!-- Buttons -->
                                <HBox alignment="CENTER_RIGHT" spacing="10">
                                    <children>
                                        <Button onAction="#retourListe" text="❌ Annuler"
                                                style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                                                       -fx-padding: 10 25; -fx-background-radius: 8; -fx-cursor: hand;">
                                            <font><Font name="System Bold" size="13"/></font>
                                        </Button>
                                        <Button onAction="#avancerStatut" text="✅ Confirmer le changement"
                                                style="-fx-background-color: #27ae60; -fx-text-fill: white;
                                                       -fx-padding: 10 25; -fx-background-radius: 8; -fx-cursor: hand;">
                                            <font><Font name="System Bold" size="13"/></font>
                                        </Button>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <!-- Historique Table -->
                        <VBox spacing="10"
                              style="-fx-background-color: white; -fx-background-radius: 12;
                                     -fx-padding: 20;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 3);">
                            <children>
                                <Label text="📜 Historique des changements"
                                       style="-fx-font-weight: bold; -fx-font-size: 15; -fx-text-fill: #2c3e50;" />
                                <TableView fx:id="historiqueTable" prefHeight="200">
                                    <columns>
                                        <TableColumn fx:id="ancienStatutCol" text="Ancien Statut" prefWidth="110" />
                                        <TableColumn fx:id="nouveauStatutCol" text="Nouveau Statut" prefWidth="110" />
                                        <TableColumn fx:id="acteurCol" text="Par" prefWidth="200" />
                                        <TableColumn fx:id="dateActionCol" text="Date" prefWidth="150" />
                                        <TableColumn fx:id="commentaireCol" text="Commentaire" prefWidth="200" />
                                    </columns>
                                </TableView>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>