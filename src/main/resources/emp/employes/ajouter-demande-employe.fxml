<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="800.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.employers.employes.AjouterDemandeEmployeController">
    <children>
        <ScrollPane fitToWidth="true" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0"
                    AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
            <content>
                <VBox spacing="20" style="-fx-background-color: #f8f9fa;">
                    <padding>
                        <Insets bottom="30" left="40" right="40" top="30" />
                    </padding>
                    <children>
                        <!-- Header -->
                        <HBox alignment="CENTER_LEFT" spacing="15">
                            <children>
                                <Button onAction="#retourListe" text="← Retour"
                                        style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-cursor: hand;">
                                    <font><Font name="System Bold" size="12" /></font>
                                </Button>
                                <Label text="📝 Nouvelle Demande" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                            </children>
                        </HBox>

                        <Separator />

                        <!-- Form -->
                        <VBox spacing="20" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 25;
                                                  -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                            <children>
                                <!-- Title -->
                                <VBox spacing="5">
                                    <Label text="Titre de la demande *" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                                    <TextField fx:id="titreField" promptText="Entrez un titre descriptif" prefHeight="40"
                                               style="-fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #ddd;" />
                                    <Label fx:id="titreError" textFill="red" style="-fx-font-size: 11;" />
                                </VBox>

                                <!-- Category and Type Row -->
                                <HBox spacing="20">
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                        <Label text="Catégorie *" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                                        <ComboBox fx:id="categorieCombo" promptText="Sélectionnez une catégorie"
                                                  prefHeight="40" maxWidth="Infinity"
                                                  style="-fx-background-radius: 5;" />
                                        <Label fx:id="categorieError" textFill="red" style="-fx-font-size: 11;" />
                                    </VBox>
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                        <Label text="Type de demande *" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                                        <ComboBox fx:id="typeDemandeCombo" promptText="Sélectionnez un type"
                                                  prefHeight="40" maxWidth="Infinity"
                                                  style="-fx-background-radius: 5;" />
                                        <Label fx:id="typeError" textFill="red" style="-fx-font-size: 11;" />
                                    </VBox>
                                </HBox>

                                <!-- Priority and Date Row -->
                                <HBox spacing="20">
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                        <Label text="Priorité *" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                                        <ComboBox fx:id="prioriteCombo" promptText="Sélectionnez la priorité"
                                                  prefHeight="40" maxWidth="Infinity"
                                                  style="-fx-background-radius: 5;" />
                                        <Label fx:id="prioriteError" textFill="red" style="-fx-font-size: 11;" />
                                    </VBox>
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                        <Label text="Date *" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                                        <DatePicker fx:id="dateCreationPicker" prefHeight="40" maxWidth="Infinity"
                                                    style="-fx-background-radius: 5;" />
                                        <Label fx:id="dateError" textFill="red" style="-fx-font-size: 11;" />
                                    </VBox>
                                </HBox>

                                <!-- Description -->
                                <VBox spacing="5">
                                    <Label text="Description *" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                                    <TextArea fx:id="descriptionArea" promptText="Décrivez votre demande en détail..."
                                              prefRowCount="4" wrapText="true"
                                              style="-fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #ddd;" />
                                    <Label fx:id="descriptionError" textFill="red" style="-fx-font-size: 11;" />
                                </VBox>

                                <!-- Dynamic Details -->
                                <TitledPane fx:id="detailsPane" text="📋 Détails Spécifiques" expanded="false"
                                            style="-fx-background-radius: 5;">
                                    <content>
                                        <VBox fx:id="dynamicFieldsContainer" spacing="15" style="-fx-padding: 15;">
                                            <Label text="Sélectionnez un type de demande pour voir les champs spécifiques"
                                                   style="-fx-text-fill: #999; -fx-font-style: italic;" />
                                        </VBox>
                                    </content>
                                </TitledPane>

                                <!-- Buttons -->
                                <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
                                    <Button fx:id="resetButton" onAction="#reinitialiserFormulaire" text="🔄 Réinitialiser"
                                            prefWidth="140" prefHeight="40"
                                            style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;">
                                        <font><Font name="System Bold" size="13" /></font>
                                    </Button>
                                    <Button fx:id="submitButton" onAction="#ajouterDemande" text="✅ Soumettre"
                                            prefWidth="160" prefHeight="40"
                                            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;">
                                        <font><Font name="System Bold" size="13" /></font>
                                    </Button>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>