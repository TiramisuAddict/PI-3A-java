<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.Blend?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.chart.*?>

<BorderPane fx:id="rootPane" prefHeight="700.0" prefWidth="1100.0" stylesheets="@customTheme.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.annonces.AnnonceController">

    <left>
        <VBox fx:id="sidebar" prefWidth="68.0" styleClass="sidebar" BorderPane.alignment="CENTER">
            <children>
                <Button fx:id="btnToggle" maxWidth="Infinity" onAction="#handleToggleSidebar" styleClass="nav-button, logo-button">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="20">
                            <ImageView fitHeight="22" fitWidth="22" preserveRatio="true">
                                <image>
                                    <Image url="@icons/logo.png" />
                                </image>
                                <effect>
                                    <Blend />
                                </effect>
                            </ImageView>
                            <Label style="-fx-font-weight: bold;" styleClass="nav-label" text="Momentum" />
                        </HBox>
                    </graphic>
                    <VBox.margin>
                        <Insets bottom="20.0" top="10.0" />
                    </VBox.margin>
                </Button>

                <VBox spacing="10.0">
                    <children>
                        <Button fx:id="btnHome" maxWidth="Infinity" onAction="#showHome" styleClass="nav-button, nav-active">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="20">
                                    <children>
                                        <StackPane maxWidth="25" minWidth="25">
                                            <ImageView fitHeight="22" fitWidth="22" preserveRatio="true">
                                                <image>
                                                    <Image url="@icons/home.png" />
                                                </image>
                                            </ImageView>
                                        </StackPane>
                                        <Label styleClass="nav-label" text="Home" />
                                    </children>
                                </HBox>
                            </graphic>
                        </Button>

                        <Button fx:id="btnFormation" maxWidth="Infinity" onAction="#showFormation" styleClass="nav-button">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="20">
                                    <children>
                                        <StackPane maxWidth="25" minWidth="25">
                                            <ImageView fitHeight="22" fitWidth="22" preserveRatio="true">
                                                <image>
                                                    <Image url="@icons/edit.png" />
                                                </image>
                                            </ImageView>
                                        </StackPane>
                                        <Label styleClass="nav-label" text="Formations" />
                                    </children>
                                </HBox>
                            </graphic>
                        </Button>

                        <Button fx:id="btnDemande" maxWidth="Infinity" onAction="#showDemande" styleClass="nav-button">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="20">
                                    <children>
                                        <StackPane maxWidth="25" minWidth="25">
                                            <ImageView fitHeight="22" fitWidth="22" preserveRatio="true">
                                                <image>
                                                    <Image url="@icons/send.png" />
                                                </image>
                                            </ImageView>
                                        </StackPane>
                                        <Label styleClass="nav-label" text="Demandes" />
                                    </children>
                                </HBox>
                            </graphic>
                        </Button>

                        <Button fx:id="btnEmployer" maxWidth="Infinity" onAction="#showEmployer" styleClass="nav-button">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="20">
                                    <children>
                                        <StackPane maxWidth="25" minWidth="25">
                                            <ImageView fitHeight="22" fitWidth="22" preserveRatio="true">
                                                <image>
                                                    <Image url="@icons/users.png" />
                                                </image>
                                            </ImageView>
                                        </StackPane>
                                        <Label styleClass="nav-label" text="Utilisateurs" />
                                    </children>
                                </HBox>
                            </graphic>
                        </Button>

                        <Button fx:id="btnProjet" maxWidth="Infinity" onAction="#showProjet" styleClass="nav-button">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="20">
                                    <children>
                                        <StackPane maxWidth="25" minWidth="25">
                                            <ImageView fitHeight="22" fitWidth="22" preserveRatio="true">
                                                <image>
                                                    <Image url="@icons/layout.png" />
                                                </image>
                                            </ImageView>
                                        </StackPane>
                                        <Label styleClass="nav-label" text="Projets" />
                                    </children>
                                </HBox>
                            </graphic>
                        </Button>

                        <Button fx:id="btnOffre" maxWidth="Infinity" onAction="#showOffres" styleClass="nav-button">
                            <graphic>
                                <HBox alignment="CENTER_LEFT" spacing="20">
                                    <children>
                                        <StackPane maxWidth="25" minWidth="25">
                                            <ImageView fitHeight="22" fitWidth="22" preserveRatio="true">
                                                <image>
                                                    <Image url="@icons/share.png" />
                                                </image>
                                            </ImageView>
                                        </StackPane>
                                        <Label styleClass="nav-label" text="Offres d'emploi" />
                                    </children>
                                </HBox>
                            </graphic>
                        </Button>
                    </children>
                </VBox>
            </children>
        </VBox>
    </left>

    <center>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-padding: 24 40; -fx-background-color: white; -fx-border-color: #eaeef3; -fx-border-width: 0 0 1 0;">
                <Label text="Administration" style="-fx-font-size: 28px; -fx-font-weight: 700; -fx-text-fill: #1a1f36;"/>
            </HBox>

            <TabPane fx:id="mainTabPane" VBox.vgrow="ALWAYS" styleClass="custom-tab-pane" tabClosingPolicy="UNAVAILABLE">

                <!-- TAB 1: GESTION DES POSTS -->
                <Tab text="Posts" closable="false">
                    <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="main-scroll-pane">
                        <VBox spacing="24" style="-fx-padding: 32 40; -fx-background-color: #f5f7fa;">

                            <VBox spacing="20" style="-fx-background-color: white; -fx-padding: 24; -fx-background-radius: 12;">
                                <HBox alignment="CENTER_LEFT" spacing="20">
                                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                                        <Label text="Gestion des Annonces" style="-fx-font-size: 22px; -fx-font-weight: 700; -fx-text-fill: #1a1f36;"/>
                                        <Label text="Créez et gérez les annonces et événements" style="-fx-font-size: 14px; -fx-text-fill: #697386;"/>
                                    </VBox>

                                    <Button fx:id="btnAjouter" onAction="#handleShowAddForm"
                                            style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 12 24; -fx-font-weight: 700; -fx-font-size: 14px; -fx-cursor: hand;">
                                        <graphic>
                                            <Label text="+ Ajouter" style="-fx-text-fill: white; -fx-font-weight: 700;"/>
                                        </graphic>
                                    </Button>
                                </HBox>

                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <TextField fx:id="txtRecherchePost" promptText="Rechercher par titre ou contenu..."
                                               prefWidth="350"
                                               style="-fx-background-color: #f8fafc; -fx-background-radius: 8; -fx-padding: 10 16; -fx-border-color: #dfe3e8; -fx-border-radius: 8; -fx-border-width: 1.5;"/>

                                    <Button onAction="#rechercherPosts"
                                            style="-fx-background-color: #1a1f36; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 10 20; -fx-font-weight: 600; -fx-cursor: hand;">
                                        <graphic>
                                            <Label text="Rechercher" style="-fx-text-fill: white; -fx-font-weight: 600;"/>
                                        </graphic>
                                    </Button>

                                    <Region HBox.hgrow="ALWAYS"/>

                                    <Label text="Filtrer:" style="-fx-font-weight: 600; -fx-text-fill: #525f7f;"/>

                                    <Button onAction="#showAll" styleClass="btn-filter-clean" text="Tous"/>
                                    <Button onAction="#filterAnnonces" styleClass="btn-filter-clean" text="Annonces"/>
                                    <Button onAction="#filterEvents" styleClass="btn-filter-clean" text="Événements"/>
                                </HBox>
                            </VBox>

                            <VBox fx:id="formContainer" managed="false" visible="false" spacing="20"
                                  style="-fx-background-color: white; -fx-padding: 28; -fx-background-radius: 12;">

                                <Label fx:id="formTitle" text="Ajouter une Annonce"
                                       style="-fx-font-size: 20px; -fx-font-weight: 700; -fx-text-fill: #1a1f36;"/>

                                <VBox spacing="8">
                                    <Label text="Titre *" style="-fx-font-weight: 600; -fx-text-fill: #1a1f36; -fx-font-size: 14px;"/>
                                    <TextField fx:id="txtTitre" promptText="Entrez le titre de l'annonce" styleClass="form-input-pro"/>
                                    <Label fx:id="lblTitreError" styleClass="error-label" visible="false" managed="false"/>
                                </VBox>

                                <VBox spacing="8">
                                    <Label text="Contenu *" style="-fx-font-weight: 600; -fx-text-fill: #1a1f36; -fx-font-size: 14px;"/>
                                    <TextArea fx:id="txtContenu" prefRowCount="4" promptText="Entrez le contenu"
                                              styleClass="form-input-pro" wrapText="true"/>
                                    <Label fx:id="lblContenuError" styleClass="error-label" visible="false" managed="false"/>
                                </VBox>

                                <HBox spacing="20">
                                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                                        <Label text="Type *" style="-fx-font-weight: 600; -fx-text-fill: #1a1f36; -fx-font-size: 14px;"/>
                                        <ComboBox fx:id="comboTypePost" promptText="Sélectionnez le type"
                                                  styleClass="form-input-pro" prefWidth="200"/>
                                        <Label fx:id="lblTypeError" styleClass="error-label" visible="false" managed="false"/>
                                    </VBox>

                                    <VBox spacing="8" alignment="CENTER_LEFT">
                                        <Label text=" " style="-fx-font-size: 14px;"/>
                                        <CheckBox fx:id="chkActive" text="Annonce active" selected="true"
                                                  style="-fx-font-weight: 600; -fx-text-fill: #1a1f36;"/>
                                    </VBox>
                                </HBox>

                                <VBox fx:id="eventFieldsContainer" spacing="16" managed="false" visible="false">
                                    <Separator style="-fx-background-color: #eaeef3;"/>
                                    <Label text="Informations Événement"
                                           style="-fx-font-size: 16px; -fx-font-weight: 700; -fx-text-fill: #1a1f36;"/>

                                    <HBox spacing="16">
                                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                                            <Label text="Date début" style="-fx-font-weight: 600; -fx-text-fill: #1a1f36; -fx-font-size: 14px;"/>
                                            <DatePicker fx:id="dateEvenement" promptText="Date" styleClass="form-input-pro"/>
                                        </VBox>

                                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                                            <Label text="Date fin" style="-fx-font-weight: 600; -fx-text-fill: #1a1f36; -fx-font-size: 14px;"/>
                                            <DatePicker fx:id="dateFinEvenement" promptText="Date fin" styleClass="form-input-pro"/>
                                        </VBox>
                                    </HBox>

                                    <HBox spacing="16">
                                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                                            <Label text="Lieu" style="-fx-font-weight: 600; -fx-text-fill: #1a1f36; -fx-font-size: 14px;"/>
                                            <TextField fx:id="txtLieu" promptText="Lieu de l'événement" styleClass="form-input-pro"/>
                                        </VBox>

                                        <VBox spacing="8">
                                            <Label text="Capacité max" style="-fx-font-weight: 600; -fx-text-fill: #1a1f36; -fx-font-size: 14px;"/>
                                            <TextField fx:id="txtCapaciteMax" promptText="Ex: 50"
                                                       styleClass="form-input-pro" prefWidth="150"/>
                                            <Label fx:id="lblCapaciteError" styleClass="error-label" visible="false" managed="false"/>
                                        </VBox>
                                    </HBox>
                                </VBox>

                                <HBox spacing="12" alignment="CENTER_RIGHT">
                                    <Button fx:id="btnSave" onAction="#handleSave" text="Enregistrer"
                                            style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 12 28; -fx-font-weight: 700; -fx-cursor: hand;"/>
                                    <Button fx:id="btnUpdate" onAction="#handleUpdate" text="Modifier" visible="false" managed="false"
                                            style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 12 28; -fx-font-weight: 700; -fx-cursor: hand;"/>
                                    <Button onAction="#handleCancelForm" text="Annuler"
                                            style="-fx-background-color: #f8fafc; -fx-text-fill: #525f7f; -fx-background-radius: 8; -fx-padding: 12 28; -fx-font-weight: 600; -fx-border-color: #dfe3e8; -fx-border-width: 1.5; -fx-border-radius: 8; -fx-cursor: hand;"/>
                                </HBox>
                            </VBox>

                            <VBox fx:id="postsContainer" spacing="16"/>
                        </VBox>
                    </ScrollPane>
                </Tab>

                <!-- TAB 2: COMMENTAIRES PAR POST -->
                <Tab text="Commentaires" closable="false">
                    <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="main-scroll-pane">
                        <VBox spacing="24" style="-fx-padding: 32 40; -fx-background-color: #f5f7fa;">

                            <VBox spacing="16" style="-fx-background-color: white; -fx-padding: 24; -fx-background-radius: 12;">
                                <Label text="Commentaires par Post"
                                       style="-fx-font-size: 22px; -fx-font-weight: 700; -fx-text-fill: #1a1f36;"/>
                                <Label text="Gérez les commentaires organisés par publication"
                                       style="-fx-font-size: 14px; -fx-text-fill: #697386;"/>
                            </VBox>

                            <VBox fx:id="commentsContainer" spacing="16"/>
                        </VBox>
                    </ScrollPane>
                </Tab>

                <!-- TAB 3: STATISTIQUES PRO -->
                <Tab text="Statistiques" closable="false">
                    <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="main-scroll-pane">
                        <VBox spacing="24" style="-fx-padding: 32 40; -fx-background-color: #f5f7fa;">

                            <VBox spacing="16" style="-fx-background-color: white; -fx-padding: 24; -fx-background-radius: 12;">
                                <Label text="Tableau de Bord"
                                       style="-fx-font-size: 22px; -fx-font-weight: 700; -fx-text-fill: #1a1f36;"/>
                                <Label text="Vue d'ensemble des performances"
                                       style="-fx-font-size: 14px; -fx-text-fill: #697386;"/>
                            </VBox>

                            <GridPane hgap="16" vgap="16">
                                <VBox spacing="12" style="-fx-background-color: white; -fx-padding: 24; -fx-background-radius: 12;"
                                      GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <Label text="Total Posts" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #697386;"/>
                                    <Label fx:id="lblTotalPosts" text="0"
                                           style="-fx-font-size: 36px; -fx-font-weight: 700; -fx-text-fill: #1a1f36;"/>
                                    <Label fx:id="lblPostsChange" text="+12% ce mois"
                                           style="-fx-font-size: 12px; -fx-text-fill: #10b981; -fx-font-weight: 600;"/>
                                </VBox>

                                <VBox spacing="12" style="-fx-background-color: white; -fx-padding: 24; -fx-background-radius: 12;"
                                      GridPane.columnIndex="1" GridPane.rowIndex="0">
                                    <Label text="Total Likes" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #697386;"/>
                                    <Label fx:id="lblTotalLikes" text="0"
                                           style="-fx-font-size: 36px; -fx-font-weight: 700; -fx-text-fill: #ef4444;"/>
                                    <Label fx:id="lblLikesChange" text="+23% ce mois"
                                           style="-fx-font-size: 12px; -fx-text-fill: #10b981; -fx-font-weight: 600;"/>
                                </VBox>

                                <VBox spacing="12" style="-fx-background-color: white; -fx-padding: 24; -fx-background-radius: 12;"
                                      GridPane.columnIndex="2" GridPane.rowIndex="0">
                                    <Label text="Total Commentaires" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #697386;"/>
                                    <Label fx:id="lblTotalComments" text="0"
                                           style="-fx-font-size: 36px; -fx-font-weight: 700; -fx-text-fill: #3b82f6;"/>
                                    <Label fx:id="lblCommentsChange" text="+8% ce mois"
                                           style="-fx-font-size: 12px; -fx-text-fill: #10b981; -fx-font-weight: 600;"/>
                                </VBox>
                            </GridPane>

                            <HBox spacing="16">
                                <VBox spacing="16" style="-fx-background-color: white; -fx-padding: 24; -fx-background-radius: 12;"
                                      HBox.hgrow="ALWAYS">
                                    <Label text="Répartition des Posts"
                                           style="-fx-font-size: 16px; -fx-font-weight: 700; -fx-text-fill: #1a1f36;"/>
                                    <PieChart fx:id="chartPostTypes" prefHeight="250" legendVisible="true"/>
                                </VBox>

                                <VBox spacing="16" style="-fx-background-color: white; -fx-padding: 24; -fx-background-radius: 12;"
                                      HBox.hgrow="ALWAYS">
                                    <Label text="Engagement par Post"
                                           style="-fx-font-size: 16px; -fx-font-weight: 700; -fx-text-fill: #1a1f36;"/>
                                    <BarChart fx:id="chartEngagement" prefHeight="250" legendVisible="false">
                                        <xAxis>
                                            <CategoryAxis label="Posts" side="BOTTOM"/>
                                        </xAxis>
                                        <yAxis>
                                            <NumberAxis label="Interactions" side="LEFT"/>
                                        </yAxis>
                                    </BarChart>
                                </VBox>
                            </HBox>

                            <VBox spacing="16" style="-fx-background-color: white; -fx-padding: 24; -fx-background-radius: 12;">
                                <Label text="Activité Mensuelle"
                                       style="-fx-font-size: 16px; -fx-font-weight: 700; -fx-text-fill: #1a1f36;"/>
                                <LineChart fx:id="chartActivity" prefHeight="300" legendVisible="true">
                                    <xAxis>
                                        <CategoryAxis label="Mois" side="BOTTOM"/>
                                    </xAxis>
                                    <yAxis>
                                        <NumberAxis label="Nombre" side="LEFT"/>
                                    </yAxis>
                                </LineChart>
                            </VBox>

                            <VBox fx:id="detailedStatsContainer" spacing="16"/>
                        </VBox>
                    </ScrollPane>
                </Tab>

            </TabPane>
        </VBox>
    </center>
</BorderPane>
